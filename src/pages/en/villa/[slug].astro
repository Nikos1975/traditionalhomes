---
import fs from 'node:fs';
import path from 'node:path';
import Base from '../../../layouts/Base.astro';
import GalleryA from '../../../components/GalleryA.astro';
import AtAGlance from '../../../components/AtAGlance.astro';
import inventory from '../../../inventory/inventory.json';
import { validateInventory } from '../../../utils/validateInventory';
import galleryData from '../../../data/gallery.json';
import siteCopy from '../../../data/siteCopy.json';
import SinglePinMap from '../../../components/maps/SinglePinMap.astro';
import { locations, parkingOnly } from '../../../data/locations';
import { getArrivalInstructions } from '../../../utils/arrival';
import { getEntry, render } from 'astro:content';
import type { InventoryUnit, GalleryImage } from '../../../types';

export async function getStaticPaths() {
  const units = inventory as InventoryUnit[];
  validateInventory(units);
  return units
    .filter((u) => u.type === 'villa')
    .map((unit) => ({ params: { slug: unit.slug } }));
}

const { slug } = Astro.params;
const units = inventory as InventoryUnit[];
const unit = units.find((u) => u.slug === slug && u.type === 'villa');

if (!unit) {
  return Astro.redirect('/en/houses/', 302);
}

const gallery = (galleryData as Record<string, GalleryImage[]>)[slug] ?? [];

const heroDir = path.join(process.cwd(), 'public', 'images', 'villa', slug, '2400');
let heroImage = '';
if (fs.existsSync(heroDir)) {
  const files = fs.readdirSync(heroDir).filter(f => f.includes('2400') && f.endsWith('.webp'));
  if (files.length > 0) {
    heroImage = `/images/villa/${slug}/2400/${files[0]}`;
  }
}

const ogImagePath = path.join(process.cwd(), 'public', 'images', 'villa', slug, 'og.jpg');
const ogImage = fs.existsSync(ogImagePath) ? `/images/villa/${slug}/og.jpg` : undefined;

const pageTitle = `${unit.name} — ${unit.location}, Elounda | Elounda Traditional Homes`;
const pageDescription = `${unit.name} in ${unit.location} — sleeps ${unit.sleeps}, ${unit.bedrooms} bedrooms, private pool. Panoramic views over Elounda Bay and the Mirabello Gulf, Crete.`;

const locData = locations.find(l => l.slug === slug);
const parkingLoc = parkingOnly[0];
const arrivalInfo = locData && parkingLoc 
  ? getArrivalInstructions(locData.googleMapsUrl, parkingLoc.googleMapsUrl)
  : null;

const entry = await getEntry('villa', slug);
if (!entry) {
  return Astro.redirect('/en/houses/', 302);
}
const { Content } = await render(entry);
---

<Base
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={`https://traditional-homes.gr/en/villa/${slug}/`}
  ogImage={ogImage}
>

  {heroImage && (
    <section class="relative overflow-hidden bg-stone-800" aria-label="Hero" style="height: 60vh; min-height: 400px; max-height: 800px;">
      <div class="absolute inset-0 bg-gradient-to-b from-stone-900/40 via-transparent to-stone-900/60 z-10"></div>
      <div
        class="absolute inset-0 bg-center bg-cover"
        style={`background-image: url('${heroImage}');`}
        role="img"
        aria-label={`Hero image of ${unit.name}`}
      ></div>
      <div class="relative z-20 site-max site-pad h-full flex flex-col justify-end pb-8 md:pb-12">
        <div class="flex items-center gap-3 mb-2">
          <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-white drop-shadow-md">{unit.name}</h1>
          <span class="badge bg-accent-sage text-stone-900 mt-1 shadow-sm border border-accent-sage">Villa</span>
        </div>
        <p class="text-white/90 text-lg drop-shadow-md">{unit.location}, {unit.area}, Crete</p>
      </div>
    </section>
  )}

  <div class="site-max site-pad py-10 md:py-14">

    <nav class="text-xs text-muted mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-1.5" role="list">
        <li><a href="/en/" class="hover:text-body-text transition-colors duration-150">Home</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/en/houses/" class="hover:text-body-text transition-colors duration-150">Houses &amp; Villa</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-body-text font-medium" aria-current="page">{unit.name}</li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <div class="lg:col-span-2">

        {!heroImage && (
          <div class="mb-6">
            <div class="flex items-center gap-3 mb-1">
              <h1 class="font-serif text-4xl md:text-5xl text-body-text">{unit.name}</h1>
              <span class="badge bg-accent-sage text-stone-900 mt-1">Villa</span>
            </div>
            <p class="text-muted">{unit.location}, {unit.area}, Crete</p>
          </div>
        )}

        <GalleryA images={gallery} unitName={unit.name} />

        <AtAGlance unit={unit} />

        <div class="prose prose-stone max-w-none mb-10 text-stone-700 leading-relaxed">
          <Content />
        </div>

        <section class="mb-8" aria-label="Amenities">
          <h2 class="font-sans font-semibold text-sm uppercase tracking-wider text-muted mb-4">What's included</h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {unit.amenities.map((amenity) => (
              <li class="flex items-center gap-2 text-sm text-stone-700">
                <svg class="flex-shrink-0 text-success" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {amenity}
              </li>
            ))}
          </ul>
        </section>

        {unit.locationRelations?.above && (
          <div class="mb-8 p-4 bg-stone-200 border border-stone-300 rounded-lg text-sm text-stone-700">
            <p class="font-medium mb-1">Location note</p>
            <p>
              The village of Vrouchas sits above the houses in Mavrikiano. {unit.locationRelations.above} from here.
              <a href="/en/location/" class="underline hover:text-body-text ml-1 transition-colors duration-150">Location details</a>
            </p>
          </div>
        )}

        {locData && (
          <section class="mb-8 border-t border-stone-200 pt-8" aria-label="Location Map">
            <h2 class="font-sans font-semibold text-sm uppercase tracking-wider text-muted mb-4">Location</h2>
            
            <div class="mb-6">
              <a href={locData.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="btn-outline text-sm mb-6 inline-flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                Open in Google Maps
              </a>

              {arrivalInfo && (
                <div class="bg-accent-sage-soft border border-accent-sage/60 rounded-2xl p-6 text-sm text-stone-700 space-y-3 mt-4">
                  <h3 class="font-serif text-lg text-stone-950 mb-2">Arrival instructions</h3>
                  <p class="flex items-start gap-2">
                    <span class="w-7 h-7 rounded-full border border-accent-sage flex items-center justify-center text-xs font-bold flex-shrink-0">1</span>
                    <span>Arrive at the private parking first — <a href={parkingLoc?.googleMapsUrl} target="_blank" class="underline hover:text-body-text transition-colors">View parking map</a></span>
                  </p>
                  <p class="flex items-start gap-2">
                    <span class="w-7 h-7 rounded-full border border-accent-sage flex items-center justify-center text-xs font-bold flex-shrink-0">2</span>
                    <span>Alternative: You may drop luggage briefly near the villa. — <a href={locData.googleMapsUrl} target="_blank" class="underline hover:text-body-text transition-colors">View villa map</a></span>
                  </p>
                  <p class="text-stone-500 mt-2 leading-relaxed">
                    We usually meet guests at the parking and guide them personally to the villa (Mrs Olga).<br/>
                    {arrivalInfo.earlyArrival}
                  </p>
                </div>
              )}
            </div>

            <SinglePinMap location={locData} />
          </section>
        )}

      </div>

      <aside class="lg:sticky lg:top-20 lg:self-start">
        <div class="bg-white rounded-2xl border border-stone-200 p-7 shadow-card">
          <p class="font-serif text-2xl text-body-text mb-1">{unit.name}</p>
          <p class="text-xs text-muted mb-6 uppercase tracking-wider">{unit.location} · Sleeps {unit.sleeps}</p>

          <div class="space-y-0 mb-6 divide-y divide-stone-100 text-sm">
            <div class="flex justify-between py-2.5">
              <span class="text-muted">Bedrooms</span>
              <span class="font-medium">{unit.bedrooms}</span>
            </div>
            <div class="flex justify-between py-2.5">
              <span class="text-muted">Pool</span>
              <span class="font-medium text-accent-blue">Private</span>
            </div>
            <div class="flex justify-between py-2.5">
              <span class="text-muted">Wi-Fi</span>
              <span class="font-medium text-success">Free</span>
            </div>
            <div class="flex justify-between py-2.5">
              <span class="text-muted">Pets</span>
              <span class="font-medium">≤5 kg on request</span>
            </div>
          </div>

          <a
            href={unit.availabilityUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-cta booking-cta w-full text-sm mb-3"
          >
            Check Availability
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
          <a href="/en/contact/" class="btn-outline w-full py-3 text-center block rounded-xl text-xs uppercase tracking-wider font-bold">
            Ask a question
          </a>

          <div class="mt-5 pt-4 border-t border-stone-100 text-xs text-muted text-center leading-relaxed">
            Bookings via our availability system.
            <a href="/en/policies/" class="underline hover:text-body-text transition-colors duration-150 ml-1">View policies</a>
          </div>
        </div>

        <div class="mt-4 bg-amber-50 border border-amber-100 rounded-2xl p-6">
          <h3 class="font-medium text-amber-900 mb-3 flex items-center gap-2 text-sm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            Before you book
          </h3>
          <ul class="space-y-2">
            {unit.hardConstraints.map((c) => (
              <li class="flex items-start gap-2 text-xs text-amber-900/80 leading-relaxed">
                <span class="mt-1.5 w-1 h-1 rounded-full bg-amber-400 flex-shrink-0"></span>
                {c}
              </li>
            ))}
          </ul>
          {unit.accessDetail && (
            <p class="mt-4 pt-4 border-t border-amber-200 text-xs text-amber-800/70 italic leading-relaxed">
              {unit.accessDetail}
            </p>
          )}
          <a href={siteCopy.accessAnchorUrl} class="underline hover:text-amber-700 transition-colors duration-150 mt-3 inline-block text-xs text-amber-900">
            Full access details
          </a>
        </div>

        {locData?.group === 'vrouchas' && (
          <a href="/en/guide/vrouchas/" class="mt-4 flex items-center justify-between p-4 rounded-xl border border-stone-200 bg-white hover:border-sky-300 hover:shadow-md transition-all group">
            <div class="flex flex-col">
              <span class="font-serif text-sky-900 text-base mb-0.5">Vrouchas Area Guide</span>
              <span class="text-xs text-stone-500">Discover Plaka & Spinalonga access</span>
            </div>
            <svg class="text-sky-700 opacity-50 group-hover:opacity-100 group-hover:translate-x-1 transition-all" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </a>
        )}
      </aside>

    </div>
  </div>

</Base>
