---
import Base from '../../layouts/Base.astro';
import UnitCard from '../../components/UnitCard.astro';
import MapPreview from '../../components/maps/MapPreview.astro';
import inventory from '../../inventory/inventory.json';
import siteCopy from '../../data/siteCopy.json';
import type { InventoryUnit } from '../../types';
import { validateInventory } from '../../utils/validateInventory';

const units = inventory as InventoryUnit[];
validateInventory(units);
const houses = units.filter(u => u.type === 'house');
const villa = units.find((u) => u.type === 'villa');
---

<Base
  title={`${siteCopy.siteName} | Authentic Stone Houses & Villa in Crete`}
  description={siteCopy.metaDescriptionHome}
  canonicalUrl="https://traditional-homes.gr/en/"
>

  {/* 1. EDITORIAL HERO SECTION */}
  <section class="relative h-[85vh] min-h-[600px] w-full overflow-hidden flex items-center bg-stone-900" aria-label="Hero">
    <div class="absolute inset-0 z-0">
      <div 
        class="w-full h-full bg-center bg-cover scale-105 animate-slow-zoom opacity-70"
        style="background-image: url('/images/brand/home-hero-spinalonga-2400.webp');"
        role="img"
        aria-label="View of Spinalonga island from the hillside properties"
      ></div>
      <div class="absolute inset-0 bg-gradient-to-r from-stone-950/80 via-stone-950/20 to-transparent"></div>
    </div>

    <div class="relative z-10 site-max site-pad w-full">
      <div class="max-w-3xl animate-in fade-in slide-in-from-left-8 duration-1000">
        <p class="text-[10px] md:text-xs uppercase tracking-[0.5em] text-stone-300 font-bold mb-6">
          Est. 1994 · Elounda, Crete
        </p>
        <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl text-white mb-8 leading-[1.1] tracking-tight">
          The Art of <br/> <span class="italic font-light text-stone-200">Village Living</span>
        </h1>
        <p class="font-serif italic text-xl md:text-2xl text-stone-300 max-w-xl leading-relaxed mb-10 font-light">
          {siteCopy.heroSubline}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/en/houses/" class="btn-cta bg-white text-stone-950 border-white hover:bg-primary hover:text-white hover:border-primary px-8 py-4">
            Explore the Collection
          </a>
          <a
            href={siteCopy.bookingEngineUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-cta booking-cta px-8 py-4"
          >
            Check Availability
          </a>
        </div>
      </div>
    </div>

    {/* Scroll Indicator */}
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 opacity-40 animate-bounce">
      <span class="text-[9px] uppercase tracking-[0.3em] text-white font-bold">Explore</span>
      <div class="w-px h-10 bg-gradient-to-b from-white to-transparent"></div>
    </div>
  </section>

  {/* 2. THE COLLECTION OVERVIEW */}
  <section class="site-max site-pad py-20 md:py-32" aria-label="Houses and Villa overview">
    <header class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-20">
      <div class="max-w-2xl">
        <h2 class="font-serif text-4xl md:text-6xl text-stone-950 mb-6 leading-tight">Ten houses. <span class="italic text-stone-400">One villa.</span></h2>
        <p class="text-xl text-stone-500 font-light leading-relaxed italic">
          Meticulously restored stone architecture nestled in the historic hillsides of Mavrikiano and Vrouchas.
        </p>
      </div>
      <a href="/en/houses/" class="text-stone-900 font-bold text-xs uppercase tracking-widest border-b-2 border-stone-200 hover:border-stone-950 transition-all pb-1 mb-2">
        Browse the Portfolio
      </a>
    </header>

    {/* THE GRID */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-12 mb-16">
      {houses.map((unit, index) => (
        <UnitCard unit={unit} priority={index < 3} />
      ))}
    </div>

    {/* FEATURED VILLA SECTION */}
    {villa && (
      <div class="mt-20 pt-20 border-t border-stone-100">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-4">
            <span class="text-[10px] uppercase tracking-[0.3em] font-bold text-primary mb-4 block">Signature Property</span>
            <h3 class="font-serif text-4xl md:text-5xl text-stone-950 mb-6 leading-tight">The Villa</h3>
            <p class="text-stone-500 font-light text-lg leading-relaxed mb-8">
              A private hillside sanctuary in Vrouchas, designed for unparalleled privacy and sweeping views of the Aegean.
            </p>
            <a href={`/en/villa/${villa.slug}/`} class="btn-cta">Explore the Villa</a>
          </div>
          <div class="lg:col-span-8">
            <UnitCard unit={villa} />
          </div>
        </div>
      </div>
    )}
  </section>

  {/* 3. LOCATION & LIFESTYLE */}
  <section class="bg-stone-950 text-stone-400 overflow-hidden" aria-label="Location teaser">
    <div class="site-max site-pad py-24 md:py-32 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div class="order-2 lg:order-1 relative">
         <div class="aspect-square rounded-[3rem] overflow-hidden shadow-2xl relative z-10">
            <MapPreview />
         </div>
         {/* Decorative element */}
         <div class="absolute -top-10 -left-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl"></div>
      </div>

      <div class="order-1 lg:order-2">
        <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-primary mb-6">The Setting</p>
        <h2 class="font-serif text-4xl md:text-6xl text-white mb-8 leading-tight tracking-tight">
          High Above <br/> <span class="italic text-stone-500">Elounda Bay</span>
        </h2>
        <p class="text-lg text-stone-400 font-light leading-relaxed mb-10">
          Our houses sit in the quiet enclaves of Mavrikiano and Vrouchas, where the scent of wild thyme meets the sea breeze. While the vibrant centre of Elounda is just a 5-minute drive away, life here moves at a different pace.
        </p>
        
        <ul class="space-y-6 mb-12 border-t border-stone-800 pt-10">
          {[
            { label: 'Elounda town', time: '5 min drive' },
            { label: 'Heraklion Airport (HER)', time: '70 km' },
            { label: 'Sitia Airport (JSH)', time: '40 km' }
          ].map(item => (
            <li class="flex items-center justify-between text-sm">
              <span class="text-stone-100 font-medium tracking-wide">{item.label}</span>
              <span class="text-stone-500 font-light uppercase tracking-widest text-[10px]">{item.time}</span>
            </li>
          ))}
        </ul>

        <div class="flex flex-wrap gap-4">
          <a href="/en/location/" class="btn-cta border-stone-700 text-white hover:bg-white hover:text-stone-950">Location & Travel</a>
          <a href="/en/guide/mavrikiano/" class="btn-cta bg-primary border-primary text-white hover:bg-amber-600">Local Guide</a>
        </div>
      </div>
    </div>
  </section>

  {/* 4. UTILITY GRID (FAQ / ABOUT / POLICIES) */}
  <section class="site-max site-pad py-24 md:py-32">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
      {[
        { 
          title: 'Frequently Asked', 
          desc: 'Details on Wi-Fi, village access, pet policies, and shared pool arrangements.', 
          link: '/en/faq/', 
          label: 'Read FAQ' 
        },
        { 
          title: 'Our Story', 
          desc: 'A family-run legacy of stone restoration and traditional Cretan hospitality since 1994.', 
          link: '/en/about/', 
          label: 'About us' 
        },
        { 
          title: 'Policies', 
          desc: 'Straightforward information on check-in, quiet hours, and house rules.', 
          link: '/en/policies/', 
          label: 'View policies' 
        }
      ].map(item => (
        <div class="group">
          <h3 class="font-serif text-2xl text-stone-950 mb-4 group-hover:text-primary transition-colors">{item.title}</h3>
          <p class="text-stone-500 font-light leading-relaxed mb-6 text-sm">{item.desc}</p>
          <a href={item.link} class="text-[10px] uppercase tracking-[0.2em] font-bold text-stone-950 border-b border-stone-200 hover:border-stone-950 transition-all pb-1">
            {item.label}
          </a>
        </div>
      ))}
    </div>
  </section>

  {/* 5. FINAL MASTHEAD CTA */}
  <section class="bg-stone-50 border-t border-stone-100">
    <div class="site-max site-pad py-24 md:py-32 text-center">
      <h2 class="font-serif text-5xl md:text-7xl text-stone-950 mb-8 leading-tight tracking-tight">Begin your <span class="italic text-stone-400">journey.</span></h2>
      <p class="text-stone-500 text-lg md:text-xl font-light max-w-xl mx-auto mb-12">
        Bookings are managed through our secure availability system. Select your property and dates to proceed.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={siteCopy.bookingEngineUrl} target="_blank" class="btn-cta booking-cta px-12 py-5 shadow-premium">
          Check Availability
        </a>
        <a href="/en/houses/" class="btn-cta bg-transparent border-stone-200 text-stone-950 hover:bg-stone-100 px-12 py-5">
          View All Properties
        </a>
      </div>
    </div>
  </section>

</Base>

<style>
  .animate-slow-zoom {
    animation: slowZoom 25s infinite alternate ease-in-out;
  }
  
  @keyframes slowZoom {
    from { transform: scale(1); }
    to { transform: scale(1.15); }
  }
</style>
