---
import Base from '../../../layouts/Base.astro';
import UnitCard from '../../../components/UnitCard.astro';
import GroupCard from '../../../components/GroupCard.astro';
import FilterBar from '../../../components/FilterBar.astro';
import inventory from '../../../inventory/inventory.json';
import groupsData from '../../../inventory/groups.json';
import siteCopy from '../../../data/siteCopy.json';
import type { InventoryUnit } from '../../../types';
import type { ListingItem } from '../../../utils/filters';
import { validateInventory } from '../../../utils/validateInventory';

const units = inventory as InventoryUnit[];
validateInventory(units);
const houses = units.filter((u) => u.type === 'home');
const villa = units.find((u) => u.type === 'villa');

const allItems: ListingItem[] = [
  ...units.map((unit) => ({
    id: unit.slug,
    type: unit.type as 'home' | 'villa',
    name: unit.name,
    sleepsMax: unit.sleeps_max,
    bedrooms: unit.bedrooms,
    seaView: unit.view.toLowerCase().includes('sea') || unit.view.toLowerCase().includes('bay'),
    pool: unit.pool,
    internalStairs: unit.internal_stairs,
    entryLevel: null,
  })),
  ...(groupsData as ListingItem[])
];

const totalCount = allItems.length;
---

<Base
  title="Stone Houses in Mavrikiano, Elounda | Elounda Traditional Homes"
  description={siteCopy.metaDescriptionHouses}
  canonicalUrl="https://traditional-homes.gr/en/houses/"
>

  <div class="site-max site-pad py-12 md:py-16">

    <div class="mb-10">
      <nav class="text-xs text-muted mb-4" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5" role="list">
          <li><a href="/en/" class="hover:text-body-text transition-colors duration-150">Home</a></li>
          <li aria-hidden="true">›</li>
          <li class="text-body-text font-medium" aria-current="page">Houses &amp; Villa</li>
        </ol>
      </nav>
      <h1 class="font-serif text-4xl md:text-5xl text-body-text mb-4">Houses &amp; Villa</h1>
      <p class="text-stone-600 max-w-2xl leading-relaxed">
        {houses.length} traditional stone houses in Mavrikiano village and {villa ? 'one hillside villa' : 'a villa'} in Vrouchas — all within the Elounda area of northeast Crete. We also carefully configure bundled properties for larger groups staying together.
      </p>
    </div>

    <div class="access-note mb-8 flex items-start gap-2">
      <svg class="flex-shrink-0 mt-0.5" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <span>
        <strong class="font-medium">Access note:</strong> {siteCopy.accessNoteFull}&nbsp;
        <a href={siteCopy.accessAnchorUrl} class="underline hover:text-body-text transition-colors duration-150">Full access information.</a>
        Unit-specific details are shown on each property page.
      </span>
    </div>

    <FilterBar items={allItems} />

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
      aria-label={`All ${totalCount} properties`}
    >
      {units.map((unit, index) => (
        <UnitCard unit={unit} priority={index < 3} />
      ))}
      {groupsData.map((group, index) => (
        <GroupCard group={group as ListingItem} priority={index < 3} />
      ))}
    </div>

  </div>

</Base>
