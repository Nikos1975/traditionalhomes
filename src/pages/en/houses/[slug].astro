---
import Base from '../../../layouts/Base.astro';
import GalleryA from '../../../components/GalleryA.astro';
import AtAGlance from '../../../components/AtAGlance.astro';
import SinglePinMap from '../../../components/maps/SinglePinMap.astro';
import inventory from '../../../inventory/inventory.json';
import { validateInventory } from '../../../utils/validateInventory';
import siteCopyData from '../../../data/siteCopy.json';
import { locations, parkingOnly } from '../../../data/locations';
import { getArrivalInstructions } from '../../../utils/arrival';
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { InventoryUnit, SiteCopy } from '../../../types';

export async function getStaticPaths() {
  const units = inventory as InventoryUnit[];
  validateInventory(units);
  // We include all 'home' types. If your Villa uses the same layout, include it here.
  return units
    .filter((u) => u.type === 'home' || u.slug === 'almond-tree-villa') 
    .map((unit) => ({ params: { slug: unit.slug }, props: { unit } }));
}

const { unit } = Astro.props;
const { slug } = Astro.params;
const units = inventory as InventoryUnit[];
const siteCopy = siteCopyData as SiteCopy;

// 1. DYNAMIC IMAGE LOADING
const allImages = import.meta.glob('/src/assets/images/**/*.{webp,jpg,jpeg,png}', { eager: true });
const propertyFolder = `/src/assets/images/${slug}/`;
const propertyImages = Object.keys(allImages)
  .filter(key => key.includes(propertyFolder))
  .map(key => (allImages[key] as any).default);

const heroImage = propertyImages.find(img => img.src.toLowerCase().includes('hero')) || propertyImages[0];
const ogImage = propertyImages.find(img => img.src.toLowerCase().includes('og'))?.src;

// 2. DATA RELATIONS & ARRIVAL
const nearUnits = unit.location_relations?.near
  ?.map((s) => units.find((u) => u.slug === s))
  .filter(Boolean) as InventoryUnit[];

const locData = locations.find(l => l.slug === slug);
const parkingLoc = parkingOnly[0];
const arrivalInfo = locData && parkingLoc 
  ? getArrivalInstructions(locData.googleMapsUrl, parkingLoc.googleMapsUrl) 
  : null;

// 3. CONTENT
const entry = await getEntry('houses', slug);
const Content = entry ? (await render(entry)).Content : null;

const pageTitle = `${unit.name} — ${unit.location} | Elounda Traditional Homes`;
---

<Base
  title={pageTitle}
  description={unit.access_detail}
  canonicalUrl={`https://traditional-homes.gr/en/houses/${slug}/`}
  ogImage={ogImage}
>
  {/* SECTION 1: PREMIUM HERO */}
  <header class="relative h-[65vh] min-h-[500px] overflow-hidden bg-stone-900">
    <div class="absolute inset-0 bg-black/30 z-10"></div>
    {heroImage && (
      <Image 
        src={heroImage} 
        alt={unit.name}
        width={1920}
        height={1080}
        class="absolute inset-0 w-full h-full object-cover opacity-90 transition-transform duration-[10s] ease-out hover:scale-105"
        loading="eager"
      />
    )}
    <div class="relative z-20 site-max site-pad h-full flex flex-col justify-end pb-12 text-white">
      <nav class="text-[10px] uppercase tracking-[0.4em] mb-6 opacity-80" aria-label="Breadcrumb">
        <a href="/en/" class="hover:underline">Home</a> / 
        <a href="/en/houses/" class="hover:underline mx-2">Houses</a> / 
        <span class="font-bold">{unit.name}</span>
      </nav>
      <h1 class="font-serif text-5xl md:text-7xl mb-4 leading-tight">{unit.name}</h1>
      <p class="font-sans text-xs md:text-sm uppercase tracking-[0.3em] font-light italic opacity-90">
        {unit.location} — {unit.area}, Crete
      </p>
    </div>
  </header>

  <main class="site-max site-pad py-12 md:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
      
      {/* LEFT COLUMN: THE STORY & DETAILS */}
      <div class="lg:col-span-8 space-y-16">
        
        {/* GALLERY COMPONENT */}
        <section aria-label="Property Gallery">
          <GalleryA images={propertyImages} unitName={unit.name} />
        </section>

        {/* BEFORE YOU BOOK (THE AMBER BLOCK) */}
        <section class="bg-amber-50/40 border border-amber-100 rounded-2xl p-8">
          <h2 class="font-serif text-2xl text-amber-900 mb-6 flex items-center gap-3 italic">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Essential Information
          </h2>
          <ul class="space-y-3">
            {unit.hard_constraints.map((c) => (
              <li class="flex items-start gap-3 text-sm text-amber-900/80 leading-relaxed italic">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-amber-400 flex-shrink-0"></span>
                <span>{c}</span>
              </li>
            ))}
          </ul>
        </section>

        {/* AT A GLANCE SECTION */}
        <section class="border-y border-stone-100 py-10">
          <AtAGlance unit={unit} />
        </section>

        {/* HOUSE STORY (MDX CONTENT) */}
        <section class="prose prose-stone prose-lg max-w-none text-stone-700 leading-relaxed font-light">
          {Content ? <Content /> : <p>Detailed description coming soon.</p>}
        </section>

        {/* AMENITIES */}
        <section aria-label="Amenities" class="pt-10 border-t border-stone-100">
          <h3 class="font-serif text-3xl text-body-text mb-8">Included Amenities</h3>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-4 gap-x-8">
            {unit.amenities.map((amenity) => (
              <li class="flex items-center gap-3 text-sm text-stone-600 border-b border-stone-50 pb-3">
                <svg class="text-primary/60" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                {amenity}
              </li>
            ))}
          </ul>
        </section>

        {/* LOCATION & ARRIVAL MAP */}
        {locData && (
          <section class="space-y-8 pt-10 border-t border-stone-100">
            <h3 class="font-serif text-3xl text-body-text">Location & Access</h3>
            <div class="grid md:grid-cols-2 gap-8">
               <div class="p-8 bg-stone-900 text-white rounded-[2rem] shadow-xl">
                  <h4 class="font-serif text-xl mb-4 text-primary">Arrival Instructions</h4>
                  <p class="text-sm opacity-80 leading-relaxed mb-8">
                    Your host, <strong class="text-white">{siteCopy.arrival.hostName}</strong>, will meet you at the {siteCopy.arrival.meetingPoint}.
                  </p>
                  <div class="space-y-6 text-[11px] uppercase tracking-[0.2em] font-bold">
                    <a href={parkingLoc?.googleMapsUrl} target="_blank" class="flex items-center gap-4 hover:text-primary transition-colors group">
                      <span class="w-8 h-8 rounded-full border border-white/20 flex items-center justify-center group-hover:border-primary">1</span>
                      Private Parking
                    </a>
                    <a href={locData.googleMapsUrl} target="_blank" class="flex items-center gap-4 hover:text-primary transition-colors group">
                      <span class="w-8 h-8 rounded-full border border-white/20 flex items-center justify-center group-hover:border-primary">2</span>
                      House Entrance
                    </a>
                  </div>
               </div>
               <div class="rounded-[2rem] overflow-hidden border border-stone-200 shadow-sm min-h-[300px]">
                  <SinglePinMap location={locData} />
               </div>
            </div>
          </section>
        )}
      </div>

      {/* RIGHT COLUMN: STICKY BOOKING SIDEBAR */}
      <aside class="lg:col-span-4 lg:sticky lg:top-12 space-y-8">
        
        {/* BOOKING ENGINE CARD */}
        <div class="bg-white rounded-[2.5rem] border border-stone-200 p-10 shadow-card">
          <h3 class="font-serif text-3xl text-body-text mb-6">Experience {unit.name}</h3>
          
          <div class="space-y-4 mb-10 text-[10px] uppercase tracking-widest font-bold text-stone-500">
            <div class="flex justify-between py-3 border-b border-stone-50">
              <span>Capacity</span>
              <span class="text-body-text">Up to {unit.sleeps_max} guests</span>
            </div>
            <div class="flex justify-between py-3 border-b border-stone-50">
              <span>Pool</span>
              <span class="text-body-text capitalize">{unit.pool} Pool</span>
            </div>
          </div>

          <a href={unit.availability_url} target="_blank" class="btn-cta w-full py-5 text-center block rounded-2xl shadow-lg mb-4">
            Check Availability
          </a>
          <a href="/en/contact/" class="btn-outline w-full py-5 text-center block rounded-2xl text-[10px] uppercase tracking-[0.2em] font-bold">
            Ask a Question
          </a>
        </div>

        {/* NEARBY PROPERTIES */}
        {nearUnits.length > 0 && (
          <div class="p-8 bg-stone-100/50 rounded-[2.5rem] border border-stone-200/60">
            <h4 class="text-[10px] uppercase tracking-widest text-muted font-bold mb-6">Neighboring Houses</h4>
            <div class="space-y-4">
              {nearUnits.map((near) => (
                <a href={`/en/houses/${near.slug}/`} class="group block bg-white p-5 rounded-2xl border border-stone-200 hover:border-primary transition-all shadow-sm">
                  <span class="block font-serif text-lg text-body-text group-hover:text-primary transition-colors">{near.name}</span>
                  <span class="block text-[9px] uppercase tracking-widest text-muted mt-1">
                    Sleeps {near.sleeps_max} • {near.pool} pool
                  </span>
                </a>
              ))}
            </div>
            <p class="text-[10px] text-muted italic mt-6 leading-relaxed">
              Ideal for groups looking to book neighboring properties in Mavrikiano.
            </p>
          </div>
        )}
      </aside>

    </div>
  </main>
</Base>