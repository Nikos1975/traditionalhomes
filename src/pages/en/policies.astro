---
import Base from '../../layouts/Base.astro';
import siteCopy from '../../data/siteCopy.json';

const sections = [
  { id: "access", label: "Access & Mobility" },
  { id: "check-in-out", label: "Check-in & Out" },
  { id: "pets", label: "Pet Policy" },
  { id: "wifi", label: "Connectivity" },
  { id: "quiet-hours", label: "Quiet Hours" },
  { id: "smoking", label: "Smoking" },
  { id: "cancellation", label: "Cancellation" }
];
---

<Base
  title={`Policies & House Rules | ${siteCopy.siteName}`}
  description={siteCopy.metaDescriptionPolicies}
  canonicalUrl="https://traditional-homes.gr/en/policies/"
>

  <div class="site-max site-pad py-16 md:py-24">
    
    {/* BREADCRUMB */}
    <nav class="text-[10px] uppercase tracking-[0.4em] text-stone-400 mb-12 font-bold" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2" role="list">
        <li><a href="/en/" class="hover:text-stone-900 transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-stone-200">/</li>
        <li class="text-stone-900" aria-current="page">Policies</li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
      
      {/* LEFT: STICKY NAVIGATION */}
      <aside class="hidden lg:block lg:col-span-3 sticky top-32">
        <p class="text-[10px] uppercase tracking-[0.3em] font-bold text-stone-900 mb-6">On this page</p>
        <ul class="space-y-4 border-l border-stone-100">
          {sections.map(section => (
            <li>
              <a 
                href={`#${section.id}`} 
                class="block pl-4 text-sm text-stone-500 hover:text-primary hover:border-l hover:border-primary -ml-px transition-all duration-200"
              >
                {section.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-12 p-6 bg-stone-50 rounded-2xl border border-stone-100">
           <p class="text-xs text-stone-500 leading-relaxed italic">
             "Our rules exist to ensure the harmony of village life and the comfort of all our guests."
           </p>
        </div>
      </aside>

      {/* RIGHT: CONTENT */}
      <div class="lg:col-span-8 lg:col-start-5 max-w-3xl">
        <header class="mb-16">
          <h1 class="font-serif text-5xl md:text-6xl text-stone-950 mb-6 leading-tight tracking-tight">
            House <span class="italic text-stone-400">Rules</span>
          </h1>
          <p class="text-xl text-stone-500 font-light leading-relaxed">
            Essential information regarding your stay, access requirements, and our commitment to the local community.
          </p>
        </header>

        <div class="space-y-20">

          {/* ACCESS & MOBILITY */}
          <section id="access" class="scroll-mt-32 group">
            <div class="flex items-center gap-4 mb-6">
               <span class="text-[10px] font-bold text-primary tracking-widest uppercase">01</span>
               <h2 class="font-serif text-3xl text-stone-950">Access & Mobility</h2>
            </div>
            
            <div class="bg-primary/5 border border-primary/20 rounded-[2rem] p-8 mb-8 shadow-sm">
              <div class="flex items-start gap-4 text-primary mb-4">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <p class="font-bold uppercase tracking-widest text-[11px]">Critical Arrival Information</p>
              </div>
              <p class="text-stone-900 leading-relaxed font-medium">{siteCopy.accessNoteFull}</p>
            </div>

            <div class="space-y-6 text-stone-600 font-light leading-relaxed">
              <p>
                All properties are traditional stone houses in historic hillside villages. The terrain consists of uneven cobblestones, stepped lanes, and sloped paths. <strong>None of the properties are step-free</strong>, and they are not suitable for wheelchair access.
              </p>
              <p>
                Each home has unique architectural quirks. For example, some bedrooms are accessed via external stone stairs, while others feature traditional sunken entrances.
              </p>
              <a href="/en/houses/" class="inline-flex items-center gap-2 text-stone-900 font-bold text-xs uppercase tracking-widest border-b border-stone-200 hover:border-primary transition-all pb-1 group">
                View individual property access
                <svg class="group-hover:translate-x-1 transition-transform" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
            </div>
          </section>

          {/* CHECK-IN/OUT */}
          <section id="check-in-out" class="scroll-mt-32">
            <div class="flex items-center gap-4 mb-8">
               <span class="text-[10px] font-bold text-primary tracking-widest uppercase">02</span>
               <h2 class="font-serif text-3xl text-stone-950">Arrival & Departure</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
              <div class="p-8 bg-stone-50 rounded-3xl border border-stone-100 text-center group hover:bg-stone-950 transition-colors duration-500">
                <p class="text-[10px] uppercase tracking-widest text-stone-400 font-bold mb-2 group-hover:text-primary">Check-in After</p>
                <p class="font-serif text-4xl text-stone-950 group-hover:text-white">{siteCopy.checkIn}</p>
              </div>
              <div class="p-8 bg-stone-50 rounded-3xl border border-stone-100 text-center group hover:bg-stone-950 transition-colors duration-500">
                <p class="text-[10px] uppercase tracking-widest text-stone-400 font-bold mb-2 group-hover:text-primary">Check-out By</p>
                <p class="font-serif text-4xl text-stone-950 group-hover:text-white">{siteCopy.checkOut}</p>
              </div>
            </div>
            <p class="text-stone-500 font-light text-sm italic text-center">
              Early arrivals and late departures are subject to availability and cleaning schedules.
            </p>
          </section>

          {/* REUSABLE POLICY BLOCKS */}
          {[
            { id: "pets", num: "03", title: "Pet Policy", text: `${siteCopy.pets}. Please coordinate with us prior to booking. A professional cleaning fee may apply to ensure the house is pristine for the next guest.` },
            { id: "wifi", num: "04", title: "Connectivity", text: `${siteCopy.wifi}. While we provide high-speed access, the thick stone walls may limit signal on outdoor terraces.` },
            { id: "quiet-hours", num: "05", title: "Quiet Hours", text: `Quiet hours are observed from ${siteCopy.quietHours}. We ask that you respect our local neighbors by keeping terrace noise and music to a minimum after 23:00.` },
            { id: "smoking", num: "06", title: "Smoking", text: "In accordance with health and fire safety regulations, smoking is strictly prohibited inside the properties. It is permitted on outdoor terraces; please ensure all materials are extinguished safely due to summer fire risks." },
            { id: "cancellation", num: "07", title: "Cancellation", text: siteCopy.cancellationPolicy }
          ].map(policy => (
            <section id={policy.id} class="scroll-mt-32 pt-12 border-t border-stone-100">
              <div class="flex items-center gap-4 mb-6">
                 <span class="text-[10px] font-bold text-stone-300 tracking-widest uppercase">{policy.num}</span>
                 <h2 class="font-serif text-2xl text-stone-950">{policy.title}</h2>
              </div>
              <p class="text-stone-600 font-light leading-relaxed">{policy.text}</p>
            </section>
          ))}

        </div>

        {/* FINAL FOOTER NOTES */}
        <footer class="mt-24 pt-12 border-t border-stone-100 text-center">
          <p class="text-stone-400 text-sm font-light mb-8 italic">
            Questions regarding these terms?
          </p>
          <a href="/en/contact/" class="btn-cta bg-transparent border-stone-200 text-stone-950 hover:bg-stone-50 px-12 py-5">
            Contact Guest Relations
          </a>
        </footer>
      </div>

    </div>
  </div>

</Base>

<style>
  /* Smooth scrolling for anchor links */
  html {
    scroll-behavior: smooth;
  }
</style>