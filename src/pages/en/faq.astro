---
import Base from '../../layouts/Base.astro';
import siteCopy from '../../data/siteCopy.json';

const faqs = [
  {
    q: 'Are the properties step-free or wheelchair accessible?',
    a: 'No. All properties are located in traditional stone villages with uneven terrain. Each property has at least one step from the path or parking area to the entrance. Some properties have internal stairs between floors. Full access information is available on the Policies page and on each individual property page.',
    category: 'access',
  },
  {
    q: 'Which properties have internal stairs?',
    a: "House Argyro, Leonidas, Margarita, Penelope, Erato, Clio, Efterpi, Kalliopi, Monastiri, and Almond Tree Villa all have internal stairs or split-level floors. House Demetra is the only property featuring a single-floor layout once inside. Check the individual property page for specific access detail.",
    category: 'access',
  },
  {
    q: 'Which houses share a pool?',
    a: 'House Penelope and House Demetra share a pool. The pool is for the exclusive use of guests in those two houses only. House Erato, House Monastiri, and Almond Tree Villa each feature their own private pool. The remaining houses have no pool.',
    category: 'pools',
  },
  {
    q: 'Is Wi-Fi included?',
    a: 'Yes. Free Wi-Fi is included in all properties. Coverage varies between properties due to stone wall construction — in most cases Wi-Fi reaches the terrace.',
    category: 'amenities',
  },
  {
    q: 'Are pets allowed?',
    a: 'Small pets up to 5 kg may be accepted on request. Please contact us before booking to confirm availability for your specific dates and property. A cleaning fee may apply.',
    category: 'policies',
  },
  {
    q: 'What are the check-in and check-out times?',
    a: `Check-in is from ${siteCopy.checkIn}. Check-out is by ${siteCopy.checkOut}. Early check-in or late check-out may be possible on request, subject to availability.`,
    category: 'policies',
  },
  {
    q: 'Where are the houses exactly?',
    a: 'The ten stone houses are in Mavrikiano village, on the hillside above Elounda. Villa Almyra is in Vrouchas, a few minutes further uphill. Exact GPS coordinates are provided with your booking confirmation.',
    category: 'location',
  },
  {
    q: 'Is parking available?',
    a: 'Most properties have private parking nearby or on site. Houses in the village centre use shared village parking within 50–80 metres of the entrance. Specific parking information is listed on each property page.',
    category: 'amenities',
  },
  {
    q: 'What is the cancellation policy?',
    a: siteCopy.cancellationPolicy,
    category: 'policies',
  },
];

const categories = [
  { id: 'access', label: 'Access & Mobility' },
  { id: 'pools', label: 'Pools' },
  { id: 'amenities', label: 'Amenities & Tech' },
  { id: 'location', label: 'Location' },
  { id: 'policies', label: 'Stay Policies' },
];
---

<Base
  title={`FAQ | Frequently Asked Questions | ${siteCopy.siteName}`}
  description={siteCopy.metaDescriptionFaq}
  canonicalUrl="https://traditional-homes.gr/en/faq/"
>

  <div class="site-max site-pad py-16 md:py-24">

    {/* BREADCRUMBS */}
    <nav class="text-[10px] uppercase tracking-[0.3em] text-stone-400 mb-8 font-bold" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2" role="list">
        <li><a href="/en/" class="hover:text-stone-900 transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-stone-200">/</li>
        <li class="text-stone-900" aria-current="page">FAQ</li>
      </ol>
    </nav>

    {/* HERO SECTION */}
    <div class="max-w-3xl mb-16 md:mb-24">
      <h1 class="font-serif text-5xl md:text-7xl text-stone-900 mb-8 leading-tight tracking-tight">
        Frequently Asked <span class="italic text-stone-400">Questions</span>
      </h1>
      <p class="text-xl text-stone-500 font-light leading-relaxed max-w-2xl">
        Practical information regarding the collection, village life, and our booking policies.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 relative">

      {/* STICKY SIDE NAV */}
      <aside class="lg:col-span-3 hidden lg:block">
        <div class="sticky top-32 space-y-8">
          <div>
            <p class="text-[10px] uppercase tracking-[0.3em] font-bold text-stone-400 mb-6">In this section</p>
            <nav class="flex flex-col gap-4" aria-label="FAQ categories">
              {categories.map((cat) => (
                <a 
                  href={`#${cat.id}`} 
                  class="text-sm text-stone-600 hover:text-stone-950 hover:translate-x-1 transition-all duration-300 flex items-center gap-3 group"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-stone-200 group-hover:bg-primary transition-colors"></span>
                  {cat.label}
                </a>
              ))}
            </nav>
          </div>
          
          <div class="p-6 bg-stone-50 rounded-2xl border border-stone-100">
            <p class="text-xs text-stone-500 font-light mb-4 leading-relaxed italic">Need direct assistance?</p>
            <a href="/en/contact/" class="btn-cta text-xs py-2 w-full justify-center">Contact Us</a>
          </div>
        </div>
      </aside>

      {/* FAQ CONTENT */}
      <div class="lg:col-span-9 space-y-24">
        {categories.map((cat) => {
          const items = faqs.filter((f) => f.category === cat.id);
          if (!items.length) return null;
          return (
            <section id={cat.id} aria-labelledby={`${cat.id}-heading`} class="scroll-mt-32 animate-in fade-in slide-in-from-bottom-4 duration-700">
              <h2 id={`${cat.id}-heading`} class="font-serif text-3xl text-stone-900 mb-10 flex items-baseline gap-4">
                {cat.label}
                <span class="h-px flex-1 bg-stone-100"></span>
              </h2>
              
              <dl class="space-y-12">
                {items.map((faq) => (
                  <div class="group">
                    <dt class="font-serif text-xl text-stone-900 mb-3 group-hover:text-primary transition-colors duration-300">
                      {faq.q}
                    </dt>
                    <dd class="text-stone-500 leading-relaxed font-light text-lg max-w-3xl" set:html={faq.a}></dd>
                    {faq.category === 'access' && (
                      <dd class="mt-4">
                        <a href="/en/policies/#access" class="text-xs uppercase tracking-widest font-bold text-stone-400 hover:text-stone-900 border-b border-stone-100 hover:border-stone-900 transition-all pb-1">
                          View Detailed Accessibility Guide
                        </a>
                      </dd>
                    )}
                  </div>
                ))}
              </dl>
            </section>
          );
        })}
      </div>
    </div>
    
    {/* MOBILE CALL TO ACTION */}
    <div class="mt-24 pt-12 border-t border-stone-100 text-center lg:hidden">
      <p class="font-serif text-2xl text-stone-900 mb-4 italic">Still have a question?</p>
      <a href="/en/contact/" class="btn-cta">Contact our Team</a>
    </div>

  </div>

</Base>

<style>
  /* Smooth scrolling for the category links */
  html {
    scroll-behavior: smooth;
  }
</style>