---
import Base from '../../../layouts/Base.astro';
import * as Guide from '../../../guides/Mavrikiano-Guide.md';

const { Content, frontmatter } = Guide;

// SEO & Data Prep
const pageTitle = `${frontmatter.title} | Elounda Traditional Homes`;
const pageDescription = frontmatter.description || "Practical information for your stay in Mavrikiano.";
---

<Base 
  title={pageTitle} 
  description={pageDescription}
>
  <div class="site-max site-pad py-12 md:py-20 min-h-[70vh]">
    
    {/* BREADCRUMBS - High-end letter spacing */}
    <nav class="text-[10px] uppercase tracking-[0.3em] text-stone-400 mb-12" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2" role="list">
        <li><a href="/en/" class="hover:text-stone-900 transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-stone-300">/</li>
        <li><a href="/en/location/" class="hover:text-stone-900 transition-colors">Location</a></li>
        <li aria-hidden="true" class="text-stone-300">/</li>
        <li class="text-stone-900 font-bold" aria-current="page">Area Guide</li>
      </ol>
    </nav>

    <div class="max-w-3xl mx-auto">
      <article class="prose prose-stone prose-lg max-w-none text-stone-700 leading-relaxed font-sans
                      prose-headings:font-serif prose-headings:font-normal prose-headings:text-stone-900 
                      prose-h1:text-5xl md:prose-h1:text-6xl prose-h1:mb-12 prose-h1:leading-tight
                      prose-h2:text-3xl prose-h2:mt-16 prose-h2:mb-8 prose-h2:border-b prose-h2:border-stone-200 prose-h2:pb-4
                      prose-h3:text-xl prose-h3:mt-10 prose-h3:uppercase prose-h3:tracking-widest prose-h3:text-primary
                      prose-a:text-primary prose-a:font-medium prose-a:no-underline hover:prose-a:underline
                      prose-strong:font-bold prose-strong:text-stone-900
                      prose-ul:list-none prose-ul:pl-0
                      prose-li:relative prose-li:pl-6 prose-li:before:absolute prose-li:before:left-0 prose-li:before:top-[0.6em] prose-li:before:w-1.5 prose-li:before:h-1.5 prose-li:before:bg-primary/30 prose-li:before:rounded-full
                      prose-table:border prose-table:border-stone-200 prose-table:rounded-xl prose-table:overflow-hidden
                      prose-th:bg-stone-50 prose-th:px-4 prose-th:py-3 prose-th:text-[10px] prose-th:uppercase prose-th:tracking-widest
                      prose-td:px-4 prose-td:py-3 prose-td:text-sm
                      prose-blockquote:border-l-4 prose-blockquote:border-primary/20 prose-blockquote:bg-stone-50 prose-blockquote:py-6 prose-blockquote:px-8 prose-blockquote:rounded-r-2xl prose-blockquote:italic prose-blockquote:text-stone-600">
        <Content />
      </article>

      {/* FOOTER ACTIONS - The "What's Next" loop */}
      <div class="mt-20 pt-10 border-t border-stone-200 flex flex-col sm:flex-row gap-6 justify-between items-center">
        <a href="/en/location/" class="group flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-stone-400 hover:text-stone-900 transition-all">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="group-hover:-translate-x-1 transition-transform"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          Back to Map
        </a>
        <a href="/en/houses/" class="btn-cta px-10 py-4 rounded-xl shadow-lg transition-smooth">
          Explore the Houses
        </a>
      </div>
    </div>
  </div>
</Base>
