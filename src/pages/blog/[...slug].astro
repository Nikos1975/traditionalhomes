---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(p => !p.data.draft);
  return posts.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const pubDateFormatted = entry.data.pubDate.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
});
---

<Base
  title={`${entry.data.title} | Elounda Traditional Homes`}
  description={entry.data.description}
  canonicalUrl={`https://traditional-homes.gr/blog/${entry.id}/`}
  ogImage={entry.data.image}
>
  <div class="site-max site-pad py-16 md:py-24">

    <nav class="text-[10px] uppercase tracking-[0.4em] text-stone-400 mb-12 font-bold" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2" role="list">
        <li><a href="/en/" class="hover:text-stone-900 transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-stone-200">/</li>
        <li><a href="/blog/" class="hover:text-stone-900 transition-colors">Blog</a></li>
        <li aria-hidden="true" class="text-stone-200">/</li>
        <li class="text-stone-900" aria-current="page">{entry.data.title}</li>
      </ol>
    </nav>

    <div class="max-w-3xl mx-auto">
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <time datetime={entry.data.pubDate.toISOString()} class="text-[10px] uppercase tracking-[0.3em] text-stone-400 font-bold">
            {pubDateFormatted}
          </time>
          {entry.data.category && (
            <span class="text-[10px] uppercase tracking-[0.2em] text-primary font-bold">{entry.data.category}</span>
          )}
          {entry.data.region && (
            <span class="text-[10px] uppercase tracking-[0.2em] text-stone-400">{entry.data.region}</span>
          )}
        </div>
        <h1 class="font-serif text-4xl md:text-6xl text-stone-900 mb-3 leading-tight tracking-tight">
          {entry.data.title}
        </h1>
        {entry.data.subtitle && (
          <p class="text-xl text-stone-400 font-serif italic">{entry.data.subtitle}</p>
        )}
        {entry.data.author && (
          <p class="text-stone-400 text-sm mt-3">By {entry.data.author}</p>
        )}
        {entry.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-4">
            {entry.data.tags.map(tag => (
              <span class="text-[9px] uppercase tracking-[0.15em] text-stone-400 bg-stone-50 px-2 py-0.5 rounded-full">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <article class="prose prose-stone prose-lg max-w-none text-stone-700 leading-relaxed
                      prose-headings:font-serif prose-headings:font-normal prose-headings:text-stone-900
                      prose-h2:text-3xl prose-h2:mt-14 prose-h2:mb-6 prose-h2:border-b prose-h2:border-stone-200 prose-h2:pb-4
                      prose-h3:text-xl prose-h3:mt-10
                      prose-a:text-primary prose-a:font-medium prose-a:no-underline hover:prose-a:underline
                      prose-strong:font-bold prose-strong:text-stone-900
                      prose-blockquote:border-l-4 prose-blockquote:border-primary/20 prose-blockquote:bg-stone-50 prose-blockquote:py-4 prose-blockquote:px-6 prose-blockquote:rounded-r-xl prose-blockquote:italic prose-blockquote:text-stone-600">
        <Content />
      </article>

      <div class="mt-16 pt-8 border-t border-stone-200">
        <a href="/blog/" class="group flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-stone-400 hover:text-stone-900 transition-all">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="group-hover:-translate-x-1 transition-transform"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          Back to Blog
        </a>
      </div>
    </div>

  </div>
</Base>
