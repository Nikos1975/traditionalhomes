---
const navLinks = [
  { label: 'Houses', href: '/en/houses/' },
  { label: 'Villa', href: '/en/villa/almond-tree-villa/' },
  { label: 'Location', href: '/en/location/' },
  { label: 'FAQ', href: '/en/faq/' },
  { label: 'About', href: '/en/about/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Contact', href: '/en/contact/' },
];

const currentPath = Astro.url.pathname;
const bookingUrl = 'http://traditionalhomes.reserve-online.net/';
---

<header
  class="fixed top-0 left-0 right-0 z-40 border-b border-transparent transition-all duration-500 bg-white/0"
  id="main-header"
  style="height: var(--header-h, 88px);" 
>
  <div class="site-max site-pad h-full flex items-center justify-between gap-4">

    {/* BRANDING / MASTHEAD */}
    <a
      href="/en/"
      class="flex items-center gap-4 group flex-shrink-0"
      aria-label="Elounda Traditional Homes — home"
    >
      <img 
        src="/images/brand/eh-mark.svg" 
        alt="" 
        width="48" 
        height="48" 
        class="w-12 h-12 transition-transform duration-700 ease-out group-hover:scale-110"
      />
      <div class="flex flex-col leading-none">
        <span class="font-serif text-2xl text-stone-900 group-hover:text-primary transition-colors duration-300 tracking-tight">
          Elounda Traditional Homes
        </span>
        <span class="font-sans text-[9px] uppercase text-stone-400 mt-1.5 tracking-[0.3em] font-bold">
          Mavrikiano & Vrouchas · Crete
        </span>
      </div>
    </a>

    {/* DESKTOP NAVIGATION */}
    <nav class="hidden xl:flex items-center gap-2" aria-label="Main navigation">
      {navLinks.map(({ label, href }) => {
        const isActive = currentPath === href || currentPath.startsWith(href.replace(/\/$/, '') + '/');
        return (
          <a
            href={href}
            class:list={[
              'font-sans text-[11px] uppercase tracking-[0.2em] px-4 py-2 rounded-full transition-all duration-300 font-bold',
              isActive
                ? 'text-stone-900 bg-stone-100/80 shadow-sm'
                : 'text-stone-500 hover:text-stone-900 hover:bg-stone-50'
            ]}
            aria-current={isActive ? 'page' : undefined}
          >
            {label}
          </a>
        );
      })}
    </nav>

    {/* CTA & MOBILE TOGGLE */}
    <div class="flex items-center gap-4">
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-cta hidden md:inline-flex"
      >
        Check Dates
      </a>

      <button
        id="menu-open"
        class="xl:hidden flex items-center justify-center w-12 h-12 rounded-full bg-stone-100 text-stone-700 hover:bg-stone-200 hover:text-stone-900 transition-colors duration-300"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="8" x2="20" y2="8"/><line x1="4" y1="16" x2="20" y2="16"/>
        </svg>
      </button>
    </div>
  </div>
</header>

{/* MOBILE NAVIGATION DRAWER */}
<div
  id="mobile-menu"
  role="dialog"
  aria-label="Navigation menu"
  aria-modal="true"
  class="fixed inset-0 z-50 xl:hidden hidden"
>
  <div id="menu-backdrop" class="absolute inset-0 bg-stone-900/60 backdrop-blur-sm transition-opacity" aria-hidden="true"></div>
  <nav
    class="absolute top-0 right-0 h-full w-[85vw] max-w-sm bg-stone-50 flex flex-col shadow-2xl transition-transform duration-500"
    aria-label="Mobile navigation"
  >
    <div class="flex items-center justify-between px-6 h-[88px] border-b border-stone-200 flex-shrink-0">
      <span class="font-serif text-2xl text-stone-900">Menu</span>
      <button
        id="menu-close"
        class="flex items-center justify-center w-10 h-10 rounded-full bg-stone-200 text-stone-600 hover:bg-stone-300 transition-colors duration-300"
        aria-label="Close navigation menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <ul class="flex-1 overflow-y-auto py-8 px-6 space-y-2" role="list">
      {navLinks.map(({ label, href }) => {
        const isActive = currentPath === href || currentPath.startsWith(href.replace(/\/$/, '') + '/');
        return (
          <li>
            <a
              href={href}
              class:list={[
                'block font-serif text-3xl px-4 py-3 rounded-xl transition-all duration-300',
                isActive
                  ? 'text-primary bg-stone-100'
                  : 'text-stone-500 hover:text-stone-900 hover:bg-stone-100'
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>

    <div class="p-6 border-t border-stone-200 flex-shrink-0 bg-white">
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-cta w-full justify-center"
      >
        Check Dates
      </a>
    </div>
  </nav>
</div>

{/* Spacer to prevent content from hiding under the fixed header */}
<div style="height: var(--header-h, 88px);" aria-hidden="true"></div>

<script>
  const openBtn = document.getElementById('menu-open') as HTMLButtonElement | null;
  const closeBtn = document.getElementById('menu-close') as HTMLButtonElement | null;
  const backdrop = document.getElementById('menu-backdrop');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('main-header');

  function openMenu() {
    if (!menu || !openBtn) return;
    menu.classList.remove('hidden');
    // Tiny delay to allow display:block to apply before animating opacity/transform (if you add CSS animations later)
    setTimeout(() => {
      openBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();
    }, 10);
  }

  function closeMenu() {
    if (!menu || !openBtn) return;
    openBtn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    menu.classList.add('hidden');
    openBtn.focus();
  }

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      closeMenu();
    }
  });

  // Upgraded Scroll Logic
  function handleScroll() {
    if (!header) return;
    if (window.scrollY > 20) {
      header.classList.add('bg-white/90', 'backdrop-blur-md', 'shadow-sm');
      header.classList.remove('bg-white/0');
      header.classList.replace('border-transparent', 'border-stone-200');
    } else {
      header.classList.remove('bg-white/90', 'backdrop-blur-md', 'shadow-sm');
      header.classList.add('bg-white/0');
      header.classList.replace('border-stone-200', 'border-transparent');
    }
  }
  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll(); // Check on load
</script>
