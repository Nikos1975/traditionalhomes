---
export interface MarkerData {
  id: string;
  lat: number;
  lng: number;
  title: string;
  url?: string;
  image?: string;
  subtitle?: string;
  distanceTag?: string;
}

interface Props {
  markers: MarkerData[];
  zoom?: number;
  center?: [number, number];
  height?: string;
  interactive?: boolean;
  mapId?: string;
}

const { markers, zoom = 15, center, height = '400px', interactive = true, mapId = 'map' } = Astro.props;
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style is:global>
  /* 1. CLEAN POPUP DESIGN */
  .leaflet-popup-content-wrapper {
    padding: 0;
    overflow: hidden;
    border-radius: 20px;
    box-shadow: 0 20px 25px -5px rgba(44, 36, 25, 0.15);
    border: 1px solid #E6E1D8; /* stone-300 */
  }
  
  .leaflet-popup-content {
    margin: 0 !important;
    width: 260px !important;
  }

  .custom-popup {
    display: flex;
    flex-direction: column;
    background: #FFFFFF;
  }

  .popup-img-container {
    position: relative;
    width: 100%;
    height: 140px;
    overflow: hidden;
  }

  .popup-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .custom-popup:hover .popup-img {
    transform: scale(1.08);
  }

  .popup-info {
    padding: 16px;
  }

  .popup-title {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: #2C2419; /* body-text */
    margin: 0 0 4px 0;
    line-height: 1.1;
  }

  .popup-subtitle {
    font-family: "Work Sans", sans-serif;
    font-size: 0.65rem;
    color: #6B5F50; /* muted */
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0 0 12px 0;
  }

  .popup-btn {
    display: block;
    width: 100%;
    padding: 10px;
    background: #B44B2A; /* primary */
    color: white !important;
    text-align: center;
    font-family: "Work Sans", sans-serif;
    font-size: 0.7rem;
    font-bold: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none !important;
    border-radius: 8px;
    transition: background 0.3s ease;
  }

  .popup-btn:hover {
    background: #9A3F23; /* primary-hover */
  }

  /* 2. CUSTOM SVG PIN STYLING */
  .custom-marker-pin {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pin-circle {
    width: 32px;
    height: 32px;
    background: #B44B2A;
    border: 3px solid white;
    border-radius: 50%;
    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    transition: all 0.3s ease;
  }

  .marker-active .pin-circle {
    transform: scale(1.3);
    background: #2C2419;
    border-color: #B44B2A;
  }

  /* 3. MAP OVERLAYS */
  .leaflet-container {
    background: #F7F4EE !important; /* body-bg */
  }
</style>

<div id={mapId} class="leaflet-map-container z-0 rounded-3xl" style={`height: ${height}; width: 100%;`} 
     data-markers={JSON.stringify(markers)} 
     data-zoom={zoom} 
     data-center={JSON.stringify(center)} 
     data-interactive={interactive.toString()}>
</div>

<script>
  import L from 'leaflet';

  function initMaps() {
    document.querySelectorAll<HTMLElement>('.leaflet-map-container').forEach((el) => {
      // Guard: skip if Leaflet already owns this element (e.g. hot-reload double-fire)
      if ((el as any)._leaflet_id) return;

      const markersData: any[] = JSON.parse(el.getAttribute('data-markers') || '[]');
      const zoom        = parseInt(el.getAttribute('data-zoom') || '15', 10);
      const centerAttr  = el.getAttribute('data-center');   // may be "undefined" (string)
      const interactive = el.getAttribute('data-interactive') === 'true';

      // Treat the string "undefined" (from JSON.stringify(undefined)) as absent
      const hasCenterProp = centerAttr !== null && centerAttr !== 'undefined';

      let center: [number, number] = [35.2668, 25.719]; // Elounda fallback
      if (hasCenterProp) {
        try { center = JSON.parse(centerAttr!); } catch (_) {}
      } else if (markersData.length > 0) {
        center = [markersData[0].lat, markersData[0].lng];
      }

      const map = L.map(el, {
        center,
        zoom,
        scrollWheelZoom: false,
        zoomControl: false,
        attributionControl: false,
      });

      if (interactive) {
        L.control.zoom({ position: 'bottomright' }).addTo(map);
      }

      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        maxZoom: 20,
      }).addTo(map);

      const createCustomIcon = () => L.divIcon({
        className: 'custom-marker-pin',
        html: `<div class="pin-circle"></div>`,
        iconSize: [32, 32],
        iconAnchor: [16, 16],
      });

      const bounds = L.latLngBounds([]);
      const layers: Record<string, L.Marker> = {};

      markersData.forEach((marker) => {
        if (!marker.lat || !marker.lng) return;

        const m = L.marker([marker.lat, marker.lng], { icon: createCustomIcon() }).addTo(map);
        layers[marker.id] = m;

        const popupHtml = `
          <div class="custom-popup">
            ${marker.image ? `
              <div class="popup-img-container">
                <img src="${marker.image}" alt="${marker.title}" class="popup-img" loading="lazy" />
              </div>` : ''}
            <div class="popup-info">
              <p class="popup-subtitle">${marker.subtitle || 'Traditional Home'}</p>
              <h3 class="popup-title">${marker.title}</h3>
              <div class="mt-4">
                <a href="${marker.url}" class="popup-btn">View Details</a>
              </div>
            </div>
          </div>`;

        m.bindPopup(popupHtml, { closeButton: false, offset: L.point(0, -10) });

        m.on('popupopen', () => {
          (m as any).getElement()?.classList.add('marker-active');
          el.dispatchEvent(new CustomEvent('marker-focused', {
            detail: { id: marker.id, image: marker.image },
          }));
        });
        m.on('popupclose', () => {
          (m as any).getElement()?.classList.remove('marker-active');
        });

        bounds.extend([marker.lat, marker.lng]);
      });

      // ── Zoom logic ──────────────────────────────────────────────────────────
      // Single-marker (house page): stays at the zoom prop (16 from SinglePinMap).
      // Multi-marker (location page): fitBounds only when no explicit center was given.
      if (markersData.length > 1 && !hasCenterProp) {
        map.fitBounds(bounds, { padding: [50, 50] });
      }

      // ── invalidateSize ──────────────────────────────────────────────────────
      // After a View Transition the container exists in DOM but Leaflet doesn't
      // know its pixel dimensions yet. A short delay lets the browser finish
      // layout before we force a tile recalculation.
      setTimeout(() => map.invalidateSize(), 150);

      // Expose for MasterLocationMap sidebar logic
      (window as any)[`leaflet_map_${el.id}`]    = map;
      (window as any)[`leaflet_layers_${el.id}`] = layers;
    });
  }

  // astro:page-load fires on first load AND after every View Transition swap.
  // This is the correct hook when <ViewTransitions /> is active — a plain
  // module script only runs once (on the first full page load) and is silently
  // skipped on subsequent client-side navigations.
  document.addEventListener('astro:page-load', initMaps);
</script>