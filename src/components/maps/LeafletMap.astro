---
export interface MarkerData {
  id: string;
  lat: number;
  lng: number;
  title: string;
  url?: string;
  image?: string;
  subtitle?: string;
}

interface Props {
  markers: MarkerData[];
  zoom?: number;
  center?: [number, number];
  height?: string;
  interactive?: boolean;
  mapId?: string;
}

const { markers, zoom = 15, center, height = '400px', interactive = true, mapId = 'map' } = Astro.props;
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<style is:global>
  /* Custom Leaflet Popup Styling */
  .leaflet-popup-content-wrapper {
    padding: 0;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }
  .leaflet-popup-content {
    margin: 0 !important;
    width: 240px !important;
  }
  .custom-popup {
    display: flex;
    flex-direction: column;
  }
  .popup-img {
    width: 100%;
    height: 120px;
    object-fit: cover;
    background-color: #f5f5f4;
  }
  .popup-info {
    padding: 12px;
  }
  .popup-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: #1c1917;
    margin: 0 0 2px 0;
    line-height: 1.2;
  }
  .popup-subtitle {
    font-family: 'Work Sans', sans-serif;
    font-size: 0.7rem;
    color: #78716c;
    text-transform: uppercase;
    letter-spacing: 0.025em;
    margin: 0 0 8px 0;
  }
  .popup-link {
    display: inline-block;
    font-family: 'Work Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: #615a52;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .popup-link:hover {
    color: #1c1917;
  }
  .leaflet-popup-tip {
    box-shadow: 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }
</style>

<div id={mapId} class="leaflet-map-container z-0 rounded-xl overflow-hidden" style={`height: ${height}; width: 100%;`} 
     data-markers={JSON.stringify(markers)} 
     data-zoom={zoom} 
     data-center={JSON.stringify(center)} 
     data-interactive={interactive.toString()}>
</div>

<script>
  import 'leaflet/dist/leaflet.css'; // Vite needs this for bundling properly sometimes, but we keep the CDN link above as fallback
</script>
<script>
  import L from 'leaflet';

  // Fix missing marker icons in Leaflet with webpack/vite
  delete (L.Icon.Default.prototype as any)._getIconUrl;
  L.Icon.Default.mergeOptions({
    iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
    iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
    shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
  });

  const mapElements = document.querySelectorAll('.leaflet-map-container');

  mapElements.forEach((el) => {
    if ((el as any)._leaflet_id) return; // Prevent re-initialization

    const markersData = JSON.parse(el.getAttribute('data-markers') || '[]');
    const zoom = parseInt(el.getAttribute('data-zoom') || '15', 10);
    const centerAttr = el.getAttribute('data-center');
    const interactive = el.getAttribute('data-interactive') === 'true';

    let center: [number, number] = [35.2668, 25.719]; // Default to Mavrikiano
    
    if (centerAttr && centerAttr !== 'undefined') {
      try { center = JSON.parse(centerAttr); } catch(e){}
    } else if (markersData.length > 0) {
      // Auto-center based on first marker if center not provided
      center = [markersData[0].lat, markersData[0].lng];
    }

    const map = L.map(el as HTMLElement, {
      center: center,
      zoom: zoom,
      scrollWheelZoom: false, // usually want disabled to avoid accidental scroll
      dragging: interactive,
      zoomControl: interactive,
      doubleClickZoom: interactive
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>'
    }).addTo(map);

    const bounds = L.latLngBounds([]);
    const layers: Record<string, any> = {};
    const usedPositions: string[] = [];

    markersData.forEach((marker: any) => {
      if (marker.lat && marker.lng) {
        // Resolve identical coordinates by applying a tiny offset
        let finalLat = marker.lat;
        let finalLng = marker.lng;
        const posKey = `${finalLat.toFixed(6)},${finalLng.toFixed(6)}`;
        
        if (usedPositions.includes(posKey)) {
          finalLng += 0.00004; // Visual offset for overlapping pins (e.g. Erato/Clio)
        }
        usedPositions.push(`${finalLat.toFixed(6)},${finalLng.toFixed(6)}`);

        const m = L.marker([finalLat, finalLng]).addTo(map);
        layers[marker.id] = m;

        if (marker.title) {
          const popupHtml = `
            <div class="custom-popup">
              ${marker.image ? `<img src="${marker.image}" alt="${marker.title}" class="popup-img" />` : ''}
              <div class="popup-info">
                <h3 class="popup-title">${marker.title}</h3>
                ${marker.subtitle ? `<p class="popup-subtitle">${marker.subtitle}</p>` : ''}
                ${marker.url ? `<a href="${marker.url}" class="popup-link">View details</a>` : ''}
              </div>
            </div>
          `;
          m.bindPopup(popupHtml);
        }
        bounds.extend([finalLat, finalLng]);
      }
    });

    if (markersData.length > 1 && !centerAttr) {
       map.fitBounds(bounds, { padding: [30, 30] });
    }

    // Deep link focusing logic
    const urlParams = new URLSearchParams(window.location.search);
    const targetId = urlParams.get('id');
    if (targetId && layers[targetId]) {
      const targetMarker = layers[targetId];
      setTimeout(() => {
        map.setView(targetMarker.getLatLng(), 18);
        targetMarker.openPopup();
      }, 500);
    }

    // Expose map to window for external controls
    (window as any)[`leaflet_map_${el.id}`] = map;
    (window as any)[`leaflet_layers_${el.id}`] = layers;
  });
</script>
