---
import LeafletMap from './LeafletMap.astro';
import { locations } from '../../data/locations';

// Use all properties that have coordinates defined
const allLocs = locations.filter(l => l.lat && l.lng);

const markers = allLocs.map(loc => {
  let url = '';
  if (loc.type === 'villa') {
    url = `/en/villa/${loc.slug}/`;
  } else if (loc.type === 'house' || (loc as any).type === 'home') {
    url = `/en/houses/${loc.slug}/`;
  }
  return {
    id: loc.id,
    lat: loc.lat!,
    lng: loc.lng!,
    title: loc.title,
    url: url,
    type: loc.type,
    group: loc.group,
    image: loc.image,
    subtitle: loc.subtitle
  };
});
---
<div class="master-location-map relative flex flex-col lg:flex-row gap-6 p-6 md:p-10 rounded-3xl overflow-hidden min-h-[700px]">
  
  <!-- Ambient Background Image -->
  <div id="map-ambient-bg" 
       class="absolute inset-0 z-[-1] opacity-0 transition-all duration-1000 ease-in-out bg-cover bg-center scale-105"
       style="background-image: url('/images/brand/home-hero-spinalonga-2400.webp');">
    <div class="absolute inset-0 bg-stone-50/80"></div>
  </div>

  <!-- Sidebar List & Filters -->
  <div class="w-full lg:w-1/3 flex flex-col gap-4 z-10">
    <div class="filters flex flex-wrap gap-2">
      <button class="filter-btn active px-3 py-1.5 rounded-full border border-stone-300 text-xs font-medium bg-stone-800 text-white" data-filter="all">All</button>
      <button class="filter-btn px-3 py-1.5 rounded-full border border-stone-300 text-xs font-medium hover:bg-stone-100 text-stone-700 transition-colors" data-filter="house">Houses</button>
      <button class="filter-btn px-3 py-1.5 rounded-full border border-stone-300 text-xs font-medium hover:bg-stone-100 text-stone-700 transition-colors" data-filter="villa">Villa</button>
      <button class="filter-btn px-3 py-1.5 rounded-full border border-stone-300 text-xs font-medium hover:bg-stone-100 text-stone-700 transition-colors" data-filter="mavrikiano">Mavrikiano</button>
      <button class="filter-btn px-3 py-1.5 rounded-full border border-stone-300 text-xs font-medium hover:bg-stone-100 text-stone-700 transition-colors" data-filter="vrouchas">Vrouchas</button>
    </div>

    <div class="location-list overflow-y-auto pr-2" style="max-height: 550px;">
      <div class="flex flex-col gap-3">
        {allLocs.map(loc => (
          <div class="location-card group/card relative bg-white border border-stone-200 rounded-lg p-4 cursor-pointer hover:border-stone-400 hover:shadow-md transition-all overflow-hidden" 
               data-id={loc.id} 
               data-type={loc.type} 
               data-group={loc.group}
               data-image={loc.image}>
            
            {/* Ambient Card Background */}
            {loc.image && (
              <div class="absolute inset-0 z-0 opacity-[0.20] group-hover/card:opacity-[0.40] transition-opacity duration-500 bg-cover bg-center pointer-events-none"
                   style={`background-image: url('${loc.image}')`}>
              </div>
            )}

            <div class="relative z-10">
              <h3 class="font-serif text-lg text-body-text">{loc.title}</h3>
              <p class="text-xs text-stone-500 mb-2">{loc.locationLabel}</p>
              <div class="flex justify-between items-center mt-3">
                <span class="text-[10px] uppercase font-bold tracking-wider text-stone-500 bg-stone-100/50 px-2 py-1 rounded">{loc.type}</span>
                <div class="flex flex-col items-end gap-1.5 z-10 relative">
                  {loc.googleMapsUrl && (
                    <a href={loc.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="text-[11px] font-medium text-stone-600 hover:text-stone-900 underline">View on map</a>
                  )}
                  {(loc.type === 'house' || (loc as any).type === 'home' || loc.type === 'villa') && (
                    <a href={loc.type === 'villa' ? `/en/villa/${loc.slug}/` : `/en/houses/${loc.slug}/`} class="text-[11px] font-medium text-stone-600 hover:text-stone-900 underline">View details</a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Map -->
  <div class="w-full lg:w-2/3 border border-stone-200 rounded-xl overflow-hidden shadow-lg bg-white z-10">
    <LeafletMap markers={markers} height="600px" mapId="master-map" />
  </div>
</div>

<script>
  // Handle interactive filters and map connection
  document.addEventListener('DOMContentLoaded', () => {
    // Wait for Leaflet init to complete
    setTimeout(() => {
      const mapContainer = document.getElementById('master-map');
      const map = (window as any)['leaflet_map_master-map'];
      const bgContainer = document.getElementById('map-ambient-bg');
      if (!map || !bgContainer) return;

      const filterBtns = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.location-card');
      const markersData = JSON.parse(mapContainer?.getAttribute('data-markers') || '[]');

      // Function to update ambient background
      const updateBackground = (imageUrl: string) => {
        if (!imageUrl) {
          bgContainer.style.opacity = '0';
          return;
        }
        
        // Use a temporary image to avoid flickering during load
        const tempImg = new Image();
        tempImg.onload = () => {
          bgContainer.style.backgroundImage = `url('${imageUrl}')`;
          bgContainer.style.opacity = '0.15';
          bgContainer.style.transform = 'scale(1)';
        };
        tempImg.src = imageUrl;
      };

      // Listen for marker focus events from the map
      mapContainer?.addEventListener('marker-focused', (e: any) => {
        const { id, image } = e.detail;
        
        // Highlight corresponding card
        cards.forEach(card => {
          if (card.getAttribute('data-id') === id) {
             card.classList.add('border-stone-500', 'bg-stone-50', 'ring-1', 'ring-stone-500/20');
             card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          } else {
             card.classList.remove('border-stone-500', 'bg-stone-50', 'ring-1', 'ring-stone-500/20');
          }
        });

        if (image) updateBackground(image);
      });

      // Handle card clicks
      cards.forEach(card => {
        card.addEventListener('click', (e) => {
          // Ignore clicks on links inside the card
          if ((e.target as HTMLElement).tagName.toLowerCase() === 'a') return;

          const id = card.getAttribute('data-id');
          const image = card.getAttribute('data-image');
          const marker = markersData.find((m: any) => m.id === id);
          
          if (marker) {
            // Update styling
            cards.forEach(c => {
               c.classList.remove('border-stone-500', 'bg-stone-50', 'ring-1', 'ring-stone-500/20');
            });
            card.classList.add('border-stone-500', 'bg-stone-50', 'ring-1', 'ring-stone-500/20');
            
            // Fly map to selected marker
            map.flyTo([marker.lat, marker.lng], 18, { duration: 1.2 });
            
            // Auto-open associated Leaflet popup
            const layers = (window as any)['leaflet_layers_master-map'];
            if (layers && layers[id]) {
              layers[id].openPopup();
            }

            if (image) updateBackground(image);
          }
        });
      });

      // Handle filtering
      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          // Toggle basic classes
          filterBtns.forEach(b => {
             b.classList.remove('active', 'bg-stone-800', 'text-white');
             b.classList.add('hover:bg-stone-100', 'text-stone-700');
          });
          btn.classList.add('active', 'bg-stone-800', 'text-white');
          btn.classList.remove('hover:bg-stone-100', 'text-stone-700');

          const filterMode = btn.getAttribute('data-filter');
          
          let visibleIds: string[] = [];
          
          cards.forEach(card => {
            const type = card.getAttribute('data-type');
            const group = card.getAttribute('data-group');
            
            let shouldShow = false;
            if (filterMode === 'all') shouldShow = true;
            else if (filterMode === 'house') shouldShow = type === 'house' || type === 'home';
            else if (filterMode === 'villa') shouldShow = type === 'villa';
            else if (filterMode === 'mavrikiano') shouldShow = group === 'mavrikiano';
            else if (filterMode === 'vrouchas') shouldShow = group === 'vrouchas';

            if (shouldShow) {
              (card as HTMLElement).style.display = 'block';
              visibleIds.push(card.getAttribute('data-id') as string);
            } else {
              (card as HTMLElement).style.display = 'none';
            }
          });

          if (visibleIds.length === 0) return;

          // Adjust bounds via Leaflet based on shown cards
          // @ts-ignore
          const L = window.L;
          if (L) {
            const bounds = L.latLngBounds([]);
            markersData.forEach((m: any) => {
              if (visibleIds.includes(m.id)) {
                bounds.extend([m.lat, m.lng]);
              }
            });

            if (visibleIds.length === 1) {
              map.flyTo(bounds.getCenter(), 14);
            } else {
              map.fitBounds(bounds, { padding: [30, 30] });
            }
          }
          
          // Reset background on filter change
          bgContainer.style.opacity = '0';
        });
      });
    }, 500);
  });
</script>
