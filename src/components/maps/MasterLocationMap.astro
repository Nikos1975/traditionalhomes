---
import LeafletMap from './LeafletMap.astro';
import { locations } from '../../data/locations';
import inventory from '../../inventory/inventory.json';
import type { InventoryUnit, SiteCopy } from '../../types';
import siteCopyData from '../../data/siteCopy.json';

const units = inventory as InventoryUnit[];
const siteCopy = siteCopyData as SiteCopy;

/** * 1. ASSET RESOLUTION
 * This finds every image in your /src/assets/images/ folder. 
 * Astro will optimize these (WebP, resizing) automatically.
 */
const allImages = import.meta.glob('/src/assets/images/**/*.{webp,jpg,jpeg,png}', { eager: true });

// 2. DATA MERGING
// We combine the map coordinates with the actual names/labels from your inventory
const allLocs = locations.filter(l => l.lat && l.lng).map(loc => {
  const unit = units.find(u => u.slug === loc.slug);
  
  // Find the hero image in the assets folder for this specific slug
  const propertyFolder = `/src/assets/images/${loc.slug}/`;
  const propertyImages = Object.keys(allImages).filter(key => key.includes(propertyFolder));
  
  // Get the optimized URL (the .src of the hashed file)
  const assetMatch = allImages[propertyImages.find(k => k.toLowerCase().includes('hero')) || propertyImages[0]];
  const optimizedHero = (assetMatch as any)?.default;

  return {
    ...loc,
    title: unit?.name || loc.title,
    type: unit?.type || loc.type,
    locationLabel: unit ? `${unit.location}, ${unit.area}` : loc.locationLabel,
    // Use optimized path, fallback to static path, then to placeholder
    finalImage: optimizedHero?.src || loc.image || "/images/brand/placeholder.webp" 
  };
});

// 3. MARKER PREP
// This goes into the actual Leaflet component to draw the pins
const markers = allLocs.map(loc => {
  const url = loc.type === 'villa' ? `/en/villa/${loc.slug}/` : `/en/houses/${loc.slug}/`;
  return {
    id: loc.id,
    lat: loc.lat!,
    lng: loc.lng!,
    title: loc.title,
    url: url,
    type: loc.type,
    group: loc.group,
    image: loc.finalImage,
    subtitle: loc.locationLabel,
    distanceTag: loc.distanceTag
  };
});
---

<div class="master-location-map relative flex flex-col lg:flex-row gap-8 p-4 md:p-8 bg-white rounded-[2.5rem] shadow-card border border-stone-200 overflow-hidden min-h-[750px]">
  
  {/* Ambient Background Transition Layer */}
  <div id="map-ambient-bg" 
       class="absolute inset-0 z-0 opacity-0 transition-all duration-1000 ease-in-out bg-cover bg-center pointer-events-none">
    <div class="absolute inset-0 bg-stone-50/90 backdrop-blur-sm"></div>
  </div>

  {/* Sidebar: Filters & List */}
  <div class="w-full lg:w-1/3 flex flex-col gap-6 z-10">
    <header>
      <h3 class="font-serif text-3xl text-body-text mb-4">Explore the Area</h3>
      <div class="filters flex flex-wrap gap-2">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="house">Houses</button>
        <button class="filter-btn" data-filter="villa">Villa</button>
        <button class="filter-btn" data-filter="mavrikiano">Mavrikiano</button>
        <button class="filter-btn" data-filter="vrouchas">Vrouchas</button>
      </div>
    </header>

    <div class="location-list overflow-y-auto pr-2 custom-scrollbar" style="max-height: 520px;">
      <div class="flex flex-col gap-4">
        {allLocs.map(loc => (
          <div class="location-card group/card relative bg-white border border-stone-100 rounded-2xl p-5 cursor-pointer hover:border-primary/30 hover:shadow-xl transition-all duration-500 overflow-hidden" 
               data-id={loc.id} 
               data-type={loc.type} 
               data-group={loc.group}
               data-image={loc.finalImage}>
            
            {/* Visual background hint on hover */}
            <div class="absolute inset-0 z-0 opacity-0 group-hover/card:opacity-10 transition-opacity duration-700 bg-cover bg-center"
                 style={`background-image: url('${loc.finalImage}')`}>
            </div>

            <div class="relative z-10">
              <div class="flex justify-between items-start mb-1">
                <h4 class="font-serif text-xl text-body-text group-hover/card:text-primary transition-colors">{loc.title}</h4>
                <span class="text-[9px] uppercase tracking-widest font-bold text-stone-400 bg-stone-50 px-2 py-0.5 rounded-full">{loc.type}</span>
              </div>
              <p class="text-[11px] text-muted uppercase tracking-wider mb-4">{loc.locationLabel}</p>
              
              <div class="flex justify-between items-center pt-3 border-t border-stone-50">
                <span class="text-[10px] font-medium text-stone-400 italic">{loc.distanceTag}</span>
                <div class="flex gap-4">
                  <a href={loc.googleMapsUrl} target="_blank" class="text-[10px] font-bold uppercase tracking-widest text-stone-400 hover:text-primary transition-colors">Map</a>
                  <a href={loc.type === 'villa' ? `/en/villa/${loc.slug}/` : `/en/houses/${loc.slug}/`} class="text-[10px] font-bold uppercase tracking-widest text-primary">Details</a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  {/* Interactive Map Column */}
  <div class="w-full lg:w-2/3 rounded-3xl overflow-hidden shadow-2xl bg-stone-100 z-10 border border-stone-200">
    <LeafletMap markers={markers} height="650px" mapId="master-map" />
  </div>
</div>

<style>
  .filter-btn {
    @apply px-4 py-2 rounded-full border border-stone-200 text-[10px] font-bold uppercase tracking-widest text-stone-500 transition-all hover:bg-stone-50 hover:border-stone-400;
  }
  .filter-btn.active {
    @apply bg-stone-900 border-stone-900 text-white shadow-lg;
  }
  .location-card.is-active {
    @apply border-primary ring-1 ring-primary/20 bg-stone-50/50 shadow-inner;
  }
  .custom-scrollbar::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #e6e1d8; border-radius: 10px; }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    // Small delay to ensure Leaflet is fully ready
    setTimeout(() => {
      const mapContainer = document.getElementById('master-map');
      const map = (window as any)['leaflet_map_master-map'];
      const bgContainer = document.getElementById('map-ambient-bg');
      if (!map || !bgContainer) return;

      const filterBtns = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.location-card');
      const markersData = JSON.parse(mapContainer?.getAttribute('data-markers') || '[]');

      const updateBackground = (imageUrl: string) => {
        if (!imageUrl) {
          bgContainer.style.opacity = '0';
          return;
        }
        const tempImg = new Image();
        tempImg.onload = () => {
          bgContainer.style.backgroundImage = `url('${imageUrl}')`;
          bgContainer.style.opacity = '1';
        };
        tempImg.src = imageUrl;
      };