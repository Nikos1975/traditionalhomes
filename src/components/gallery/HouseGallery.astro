---
/**
 * HouseGallery.astro
 *
 * Desktop : large hero image + horizontal thumbnail strip (max 5) + "View all" button
 * Mobile  : swipeable carousel with overlay arrows + "View all" button
 * Both    : fullscreen lightbox (keyboard · touch · swipe)
 *
 * Performance:
 *   - Hero: blur-up placeholder (480px blurred via CSS) + full image fades in on load
 *   - Hero img: loading="eager" fetchpriority="high"
 *   - All other images: loading="lazy"
 *   - Preload link is injected by the PAGE via Base layout's <slot name="head">
 *     (see [slug].astro for usage)
 *
 * Props
 *   images   – GalleryImage[] already sorted (use sortGalleryImages before passing)
 *   unitName – used for aria-labels and captions
 */
import type { GalleryImage } from '../../types';
import { placeholderSrc } from '../../utils/galleryHelpers';

interface Props {
  images: GalleryImage[];
  unitName: string;
}

const { images, unitName } = Astro.props;

if (images.length === 0) return;

// ── Derived image references ────────────────────────────────────────────────
const hero        = images[0];
const thumbImages = images.slice(1, 6);     // up to 5 thumbnails
const total       = images.length;

// Smallest srcset entry used as a CSS-blurred placeholder while hero loads.
// Falls back to hero.src if srcset is missing.
const hero480 = hero.srcset ? placeholderSrc(hero.srcset) : hero.src;

// Unique prefix so multiple gallery instances on one page never clash
const uid = 'hg-' + unitName.toLowerCase().replace(/[^a-z0-9]/g, '').slice(0, 12);

// Serialise for the client-side lightbox script
const galleryItems = images.map((img, i) => ({
  src    : img.src,
  srcset : img.srcset ?? '',
  alt    : img.alt   ?? `${unitName} — photo ${i + 1}`,
}));
---

{/* ═══════════════════════════════════════════════
    DESKTOP  (md and up)
    ═══════════════════════════════════════════════ */}
<section class="mb-10 hidden md:block" aria-label={`Photos of ${unitName}`}>

  {/* ── Hero button ────────────────────────────────────────────── */}
  <button
    class="group relative block w-full overflow-hidden rounded-2xl bg-stone-200 cursor-pointer
           focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-stone-400"
    style="aspect-ratio:16/9; max-height:65vh;"
    data-lb={uid}
    data-lb-idx="0"
    aria-label={`View photos of ${unitName}`}
  >
    {/*
      Blur-up placeholder:
        - The 480px image loads near-instantly (it's tiny)
        - CSS blur + scale-110 hides the pixellation
        - The full-resolution img fades in over the top once loaded
        - aria-hidden so screen readers skip the duplicate
    */}
    <img
      src={hero480}
      aria-hidden="true"
      alt=""
      class="absolute inset-0 w-full h-full object-cover scale-110 blur-xl pointer-events-none"
      loading="eager"
      fetchpriority="low"
      decoding="async"
    />

    {/*
      Full hero image:
        - Starts opacity-0, fades to opacity-1 via inline onload handler
        - Wrapped in a div so the group-hover scale transform is isolated
          from the opacity transition (two CSS properties on one element
          would share the same transition-duration)
    */}
    <div class="absolute inset-0 transition-transform duration-[10s] ease-out group-hover:scale-105 will-change-transform">
      <img
        src={hero.src}
        srcset={hero.srcset}
        sizes="(min-width:1280px) 900px, (min-width:1024px) 66vw, 100vw"
        alt={hero.alt ?? `Main view of ${unitName}`}
        class="w-full h-full object-cover"
        style="opacity:0; transition:opacity 0.7s ease;"
        onload="this.style.opacity='1'"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </div>

    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-500 z-10 pointer-events-none"></div>

    {/* Counter badge */}
    <span class="absolute bottom-3 right-3 z-20 px-2.5 py-1 rounded-full bg-black/50 text-white text-[11px] font-medium tabular-nums backdrop-blur-sm pointer-events-none">
      1 / {total}
    </span>
  </button>

  {/* ── Thumbnail strip + "View all" ─────────────────────────── */}
  {total > 1 && (
    <div class="mt-2 flex items-stretch gap-2">

      {thumbImages.map((img, i) => (
        <button
          type="button"
          class="group relative flex-1 min-w-0 overflow-hidden rounded-xl bg-stone-200 cursor-pointer
                 border-2 border-transparent hover:border-stone-400
                 focus-visible:border-stone-700 focus-visible:outline-none
                 transition-all duration-150"
          style="aspect-ratio:4/3;"
          data-lb={uid}
          data-lb-idx={i + 1}
          aria-label={`View photo ${i + 2} of ${unitName}`}
        >
          <img
            src={img.src}
            srcset={img.srcset}
            sizes="(min-width:1024px) 12vw, 20vw"
            alt={img.alt ?? `${unitName} — photo ${i + 2}`}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/15 transition-colors duration-300 pointer-events-none"></div>
        </button>
      ))}

      {/* "View all" tile */}
      <button
        type="button"
        class="shrink-0 flex flex-col items-center justify-center gap-1.5 px-5
               rounded-xl bg-stone-900 text-white hover:bg-stone-700
               transition-colors cursor-pointer"
        data-lb={uid}
        data-lb-idx="0"
        aria-label={`View all ${total} photos of ${unitName}`}
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
          <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
        </svg>
        <span class="text-[10px] font-bold uppercase tracking-widest leading-tight whitespace-nowrap">
          All {total}<br/>photos
        </span>
      </button>

    </div>
  )}
</section>

{/* ═══════════════════════════════════════════════
    MOBILE  (below md)
    ═══════════════════════════════════════════════ */}
<section class="mb-8 md:hidden" aria-label={`Photos of ${unitName}`}>

  {/* Carousel wrapper */}
  <div class="relative overflow-hidden rounded-2xl bg-stone-200" style="aspect-ratio:4/3;">

    {/* Track */}
    <div
      id={`${uid}-track`}
      class="flex h-full transition-transform duration-300 ease-out will-change-transform"
    >
      {images.slice(0, 12).map((img, i) => (
        <div
          class="shrink-0 w-full h-full cursor-pointer"
          data-lb={uid}
          data-lb-idx={i}
          role="button"
          tabindex={i === 0 ? '0' : '-1'}
          aria-label={`View photo ${i + 1} of ${unitName}`}
        >
          <img
            src={img.src}
            srcset={img.srcset}
            sizes="100vw"
            alt={img.alt ?? `${unitName} — photo ${i + 1}`}
            class="w-full h-full object-cover"
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>
      ))}
    </div>

    {/* Overlay arrows */}
    {total > 1 && (
      <>
        <button
          id={`${uid}-mprev`}
          class="absolute left-2 top-1/2 -translate-y-1/2 z-10
                 w-9 h-9 flex items-center justify-center
                 rounded-full bg-black/40 text-white backdrop-blur-sm
                 hover:bg-black/60 transition-colors"
          aria-label="Previous photo"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
        <button
          id={`${uid}-mnext`}
          class="absolute right-2 top-1/2 -translate-y-1/2 z-10
                 w-9 h-9 flex items-center justify-center
                 rounded-full bg-black/40 text-white backdrop-blur-sm
                 hover:bg-black/60 transition-colors"
          aria-label="Next photo"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </>
    )}

    {/* Counter */}
    <span
      id={`${uid}-mcount`}
      class="absolute bottom-2 right-3 z-10 px-2 py-0.5 rounded-full bg-black/50 text-white text-[11px] tabular-nums backdrop-blur-sm pointer-events-none"
    >
      1 / {total}
    </span>
  </div>

  {/* View all button */}
  {total > 1 && (
    <button
      type="button"
      class="mt-2 w-full flex items-center justify-center gap-2 py-3
             bg-stone-900 text-white rounded-xl
             text-[11px] font-bold uppercase tracking-widest
             hover:bg-stone-700 transition-colors cursor-pointer"
      data-lb={uid}
      data-lb-idx="0"
      aria-label={`View all ${total} photos`}
    >
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
        <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
      </svg>
      View all {total} photos
    </button>
  )}
</section>

{/* ═══════════════════════════════════════════════
    LIGHTBOX
    ═══════════════════════════════════════════════ */}
<dialog
  id={`${uid}-lb`}
  class="fixed inset-0 w-full h-full max-w-none max-h-none m-0 p-0 border-none
         bg-stone-950 text-white overflow-hidden"
  style="background-color:#09090b;"
  aria-modal="true"
  aria-label={`${unitName} — photo viewer`}
>
  <div class="w-full h-full flex flex-col">

    {/* Top bar */}
    <div class="flex items-center justify-between px-5 py-3 shrink-0 border-b border-white/10">
      <span id={`${uid}-counter`} class="font-serif text-sm tracking-widest text-white/60 tabular-nums"></span>
      <button
        id={`${uid}-close`}
        class="w-10 h-10 flex items-center justify-center rounded-full
               bg-stone-700 hover:bg-stone-500 transition-colors"
        style="color:#ffffff;"
        aria-label="Close photo viewer"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    {/* Image + arrows */}
    <div class="relative flex-1 flex items-center justify-center min-h-0 px-20">

      {/* PREV */}
      <button
        id={`${uid}-prev`}
        class="absolute left-4 z-20
               w-12 h-12 flex items-center justify-center
               rounded-full bg-white text-stone-900 shadow-2xl
               hover:scale-105 active:scale-95 transition-transform"
        aria-label="Previous photo"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>

      <img
        id={`${uid}-img`}
        src=""
        alt=""
        class="max-h-full max-w-full object-contain select-none rounded-md shadow-2xl"
      />

      {/* NEXT */}
      <button
        id={`${uid}-next`}
        class="absolute right-4 z-20
               w-12 h-12 flex items-center justify-center
               rounded-full bg-white text-stone-900 shadow-2xl
               hover:scale-105 active:scale-95 transition-transform"
        aria-label="Next photo"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
    </div>

    {/* Caption */}
    <p id={`${uid}-caption`} class="text-center text-sm text-white/40 py-3 px-8 shrink-0 font-serif italic truncate"></p>

  </div>
</dialog>

{/* ═══════════════════════════════════════════════
    CLIENT SCRIPT  (is:inline so define:vars works)
    ═══════════════════════════════════════════════ */}
<script is:inline define:vars={{ uid, galleryItems }}>
(function () {
  /* ── Lightbox ──────────────────────────────── */
  var lb      = document.getElementById(uid + '-lb');
  var lbImg   = document.getElementById(uid + '-img');
  var lbCap   = document.getElementById(uid + '-caption');
  var lbCount = document.getElementById(uid + '-counter');
  var total   = galleryItems.length;
  var idx     = 0;

  function lbShow(n) {
    if (!lb || !lbImg || total === 0) return;
    idx = (n + total) % total;
    var item = galleryItems[idx];
    lbImg.src    = item.src;
    lbImg.srcset = item.srcset || '';
    lbImg.alt    = item.alt;
    if (lbCap)   lbCap.textContent   = item.alt;
    if (lbCount) lbCount.textContent = (idx + 1) + ' / ' + total;
  }

  function lbOpen(n) {
    lbShow(n);
    lb.showModal();
    document.body.style.overflow = 'hidden';
  }

  function lbClose() {
    lb.close();
    document.body.style.overflow = '';
  }

  /* Triggers — any element with data-lb matching uid */
  document.querySelectorAll('[data-lb="' + uid + '"]').forEach(function (el) {
    el.addEventListener('click', function () {
      lbOpen(parseInt(el.getAttribute('data-lb-idx') || '0', 10));
    });
    el.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        lbOpen(parseInt(el.getAttribute('data-lb-idx') || '0', 10));
      }
    });
  });

  document.getElementById(uid + '-close')
    .addEventListener('click', lbClose);

  document.getElementById(uid + '-prev')
    .addEventListener('click', function (e) { e.stopPropagation(); lbShow(idx - 1); });

  document.getElementById(uid + '-next')
    .addEventListener('click', function (e) { e.stopPropagation(); lbShow(idx + 1); });

  lb.addEventListener('click', function (e) { if (e.target === lb) lbClose(); });

  document.addEventListener('keydown', function (e) {
    if (!lb.open) return;
    if (e.key === 'Escape')     lbClose();
    if (e.key === 'ArrowLeft')  lbShow(idx - 1);
    if (e.key === 'ArrowRight') lbShow(idx + 1);
  });

  /* Touch swipe in lightbox */
  var lbTx = 0;
  lb.addEventListener('touchstart', function (e) { lbTx = e.changedTouches[0].clientX; }, { passive: true });
  lb.addEventListener('touchend',   function (e) {
    var dx = e.changedTouches[0].clientX - lbTx;
    if (Math.abs(dx) > 60) dx > 0 ? lbShow(idx - 1) : lbShow(idx + 1);
  }, { passive: true });

  /* ── Mobile carousel ───────────────────────── */
  var track  = document.getElementById(uid + '-track');
  var mCount = document.getElementById(uid + '-mcount');
  var mPrev  = document.getElementById(uid + '-mprev');
  var mNext  = document.getElementById(uid + '-mnext');

  if (!track) return;

  var mIdx   = 0;
  var mTotal = track.children.length;

  function mSlide(n) {
    mIdx = (n + mTotal) % mTotal;
    track.style.transform = 'translateX(-' + (mIdx * 100) + '%)';
    if (mCount) mCount.textContent = (mIdx + 1) + ' / ' + total;
  }

  if (mPrev) mPrev.addEventListener('click', function (e) { e.stopPropagation(); mSlide(mIdx - 1); });
  if (mNext) mNext.addEventListener('click', function (e) { e.stopPropagation(); mSlide(mIdx + 1); });

  /* Touch swipe on mobile track */
  var mTx = 0;
  track.addEventListener('touchstart', function (e) { mTx = e.changedTouches[0].clientX; }, { passive: true });
  track.addEventListener('touchend',   function (e) {
    var dx = e.changedTouches[0].clientX - mTx;
    if (Math.abs(dx) > 40) dx > 0 ? mSlide(mIdx - 1) : mSlide(mIdx + 1);
  }, { passive: true });
})();
</script>
