---
import type { InventoryUnit } from '../types';

interface Props {
  unit: InventoryUnit;
}

const { unit } = Astro.props;

const poolLabel =
  unit.pool === 'private' ? 'Private pool'
  : unit.pool === 'shared' ? `Shared pool`
  : 'No pool';
---

<section class="mb-12" aria-labelledby="at-a-glance-title">
  
  {/* The 3-Column Grid */}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
    
    {/* Group 1: Capacity & Layout */}
    <div class="bg-stone-50/40 rounded-[2rem] p-8 border border-stone-100 shadow-sm flex flex-col gap-6 transition-colors hover:bg-stone-50/80">
      <h3 class="text-[10px] uppercase tracking-[0.2em] text-stone-400 font-bold mb-2">Capacity & Layout</h3>
      
      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-white border border-stone-200 flex items-center justify-center text-primary/70 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        </div>
        <div>
          <span class="block text-[10px] text-muted uppercase tracking-[0.1em] mb-0.5">Sleeps</span>
          <span class="block text-xl font-serif text-body-text leading-none">{unit.sleeps} Guests</span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-white border border-stone-200 flex items-center justify-center text-primary/70 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4v16"></path><path d="M2 8h18a2 2 0 0 1 2 2v10"></path><path d="M2 17h20"></path><path d="M6 8v9"></path></svg>
        </div>
        <div>
          <span class="block text-[10px] text-muted uppercase tracking-[0.1em] mb-0.5">Bedrooms</span>
          <span class="block text-xl font-serif text-body-text leading-none">{unit.bedrooms} Rooms</span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-white border border-stone-200 flex items-center justify-center text-primary/70 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
        </div>
        <div>
          <span class="block text-[10px] text-muted uppercase tracking-[0.1em] mb-0.5">Layout</span>
          <span class="block text-xl font-serif text-body-text leading-none">{unit.floors} {unit.floors === 1 ? 'Floor' : 'Floors'} · {unit.bathrooms} Baths</span>
        </div>
      </div>
    </div>

    {/* Group 2: Key Features */}
    <div class="bg-stone-50/40 rounded-[2rem] p-8 border border-stone-100 shadow-sm flex flex-col gap-6 transition-colors hover:bg-stone-50/80">
      <h3 class="text-[10px] uppercase tracking-[0.2em] text-stone-400 font-bold mb-2">Key Features</h3>

      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-white border border-stone-200 flex items-center justify-center text-accent-blue shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h20"></path><path d="M2 12c0-5.5 4.5-10 10-10s10 4.5 10 10"></path><path d="M2 12c0 5.5 4.5 10 10 10s10-4.5 10-10"></path></svg>
        </div>
        <div>
          <span class="block text-[10px] text-muted uppercase tracking-[0.1em] mb-0.5">Pool</span>
          <span class="block text-xl font-serif text-body-text leading-none">{poolLabel}</span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-white border border-stone-200 flex items-center justify-center text-primary/70 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
        </div>
        <div>
          <span class="block text-[10px] text-muted uppercase tracking-[0.1em] mb-0.5">View</span>
          <span class="block text-xl font-serif text-body-text leading-tight">{unit.view}</span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-white border border-stone-200 flex items-center justify-center text-primary/70 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
        </div>
        <div>
          <span class="block text-[10px] text-muted uppercase tracking-[0.1em] mb-0.5">Access</span>
          <span class="block text-xl font-serif text-body-text leading-none">{unit.internalStairs ? 'Stairs' : 'Step-free'}</span>
        </div>
      </div>
    </div>

    {/* Group 3: Practical Info */}
    <div class="bg-stone-50/40 rounded-[2rem] p-8 border border-stone-100 shadow-sm flex flex-col gap-6 transition-colors hover:bg-stone-50/80">
      <h3 class="text-[10px] uppercase tracking-[0.2em] text-stone-400 font-bold mb-2">Practicalities</h3>

      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-white border border-stone-200 flex items-center justify-center text-primary/70 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="22" height="18" rx="2" ry="2"></rect><path d="M8 12h8"></path><path d="M12 8v8"></path></svg>
        </div>
        <div>
          <span class="block text-[10px] text-muted uppercase tracking-[0.1em] mb-0.5">Parking</span>
          <span class="block text-xl font-serif text-body-text leading-tight capitalize">{unit.parking}</span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-white border border-stone-200 flex items-center justify-center text-success shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path><line x1="12" y1="20" x2="12.01" y2="20"></line></svg>
        </div>
        <div>
          <span class="block text-[10px] text-muted uppercase tracking-[0.1em] mb-0.5">Connectivity</span>
          <span class="block text-xl font-serif text-body-text leading-none">High-Speed Wi-Fi</span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-white border border-stone-200 flex items-center justify-center text-primary/70 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z"></path></svg>
        </div>
        <div>
          <span class="block text-[10px] text-muted uppercase tracking-[0.1em] mb-0.5">Pets</span>
          <span class="block text-xl font-serif text-body-text leading-tight">{unit.pets}</span>
        </div>
      </div>
    </div>

  </div>

  {/* Shared Pool Upsell Notice */}
  {unit.pool === 'shared' && unit.sharedPoolWith && (
    <div class="mt-8 p-6 bg-stone-100/50 border border-stone-200/60 rounded-[1.5rem] flex items-start gap-4 shadow-sm">
      <div class="w-8 h-8 rounded-full bg-white border border-stone-200 flex items-center justify-center flex-shrink-0 text-primary">
         <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      </div>
      <p class="text-sm text-stone-600 leading-relaxed font-light pt-1">
        This property's swimming pool is shared exclusively with 
        {unit.sharedPoolWith.map((slug, index) => (
          <span>
            {index > 0 ? ' and ' : ' '}
            <a href={`/en/houses/${slug}/`} class="font-medium text-body-text underline hover:text-primary transition-colors capitalize">
              {slug.replace('-', ' ')}
            </a>
          </span>
        ))}. Booking both houses together creates a private estate for your group.
      </p>
    </div>
  )}
</section>