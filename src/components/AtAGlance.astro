---
import type { InventoryUnit } from '../types';

interface Props {
  unit: InventoryUnit;
}

const { unit } = Astro.props;

const poolLabel =
  unit.pool === 'private' ? 'Private pool'
  : unit.pool === 'shared' ? `Shared pool`
  : 'No pool';
---

<section class="mb-12" aria-labelledby="at-a-glance-title">
  <h2 id="at-a-glance-title" class="font-sans font-semibold text-xs uppercase tracking-[0.2em] text-muted mb-6">At a glance</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
    
    <!-- Group 1: Capacity & Layout -->
    <div class="bg-stone-50/50 rounded-2xl p-6 border border-stone-200/60 shadow-sm flex flex-col gap-5">
      <h3 class="text-[10px] uppercase tracking-widest text-stone-400 font-bold mb-1">Capacity & Layout</h3>
      
      <div class="flex items-center gap-4">
        <div class="w-9 h-9 rounded-full bg-white border border-stone-200 flex items-center justify-center text-stone-500 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        </div>
        <div>
          <span class="block text-[11px] text-muted uppercase tracking-wider mb-0.5">Sleeps</span>
          <span class="block text-base font-medium text-body-text">{unit.sleeps_max} Guests</span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-9 h-9 rounded-full bg-white border border-stone-200 flex items-center justify-center text-stone-500 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4v16"></path><path d="M2 8h18a2 2 0 0 1 2 2v10"></path><path d="M2 17h20"></path><path d="M6 8v9"></path></svg>
        </div>
        <div>
          <span class="block text-[11px] text-muted uppercase tracking-wider mb-0.5">Bedrooms</span>
          <span class="block text-base font-medium text-body-text">{unit.bedrooms} Rooms</span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-9 h-9 rounded-full bg-white border border-stone-200 flex items-center justify-center text-stone-500 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
        </div>
        <div>
          <span class="block text-[11px] text-muted uppercase tracking-wider mb-0.5">Layout</span>
          <span class="block text-base font-medium text-body-text">{unit.floors} {unit.floors === 1 ? 'Floor' : 'Floors'} · {unit.bathrooms} Baths</span>
        </div>
      </div>
    </div>

    <!-- Group 2: Key Features -->
    <div class="bg-stone-50/50 rounded-2xl p-6 border border-stone-200/60 shadow-sm flex flex-col gap-5">
      <h3 class="text-[10px] uppercase tracking-widest text-stone-400 font-bold mb-1">Key Features</h3>

      <div class="flex items-center gap-4">
        <div class="w-9 h-9 rounded-full bg-white border border-stone-200 flex items-center justify-center text-accent-blue shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h20"></path><path d="M2 12c0-5.5 4.5-10 10-10s10 4.5 10 10"></path><path d="M2 12c0 5.5 4.5 10 10 10s10-4.5 10-10"></path></svg>
        </div>
        <div>
          <span class="block text-[11px] text-muted uppercase tracking-wider mb-0.5">Pool</span>
          <span class="block text-base font-medium text-body-text">{poolLabel}</span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-9 h-9 rounded-full bg-white border border-stone-200 flex items-center justify-center text-stone-500 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
        </div>
        <div>
          <span class="block text-[11px] text-muted uppercase tracking-wider mb-0.5">View</span>
          <span class="block text-base font-medium text-body-text">{unit.view}</span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-9 h-9 rounded-full bg-white border border-stone-200 flex items-center justify-center text-stone-500 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
        </div>
        <div>
          <span class="block text-[11px] text-muted uppercase tracking-wider mb-0.5">Level Access</span>
          <span class="block text-base font-medium text-body-text">{unit.internal_stairs ? 'Stairs' : 'Step-free'}</span>
        </div>
      </div>
    </div>

    <!-- Group 3: Practical Info -->
    <div class="bg-stone-50/50 rounded-2xl p-6 border border-stone-200/60 shadow-sm flex flex-col gap-5">
      <h3 class="text-[10px] uppercase tracking-widest text-stone-400 font-bold mb-1">Practical Info</h3>

      <div class="flex items-center gap-4">
        <div class="w-9 h-9 rounded-full bg-white border border-stone-200 flex items-center justify-center text-stone-500 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="22" height="18" rx="2" ry="2"></rect><path d="M8 12h8"></path><path d="M12 8v8"></path></svg>
        </div>
        <div>
          <span class="block text-[11px] text-muted uppercase tracking-wider mb-0.5">Parking</span>
          <span class="block text-base font-medium text-body-text capitalize">{unit.parking}</span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-9 h-9 rounded-full bg-white border border-stone-200 flex items-center justify-center text-success shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path><line x1="12" y1="20" x2="12.01" y2="20"></line></svg>
        </div>
        <div>
          <span class="block text-[11px] text-muted uppercase tracking-wider mb-0.5">Wi-Fi</span>
          <span class="block text-base font-medium text-body-text">High-speed Free</span>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-9 h-9 rounded-full bg-white border border-stone-200 flex items-center justify-center text-stone-500 shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z"></path></svg>
        </div>
        <div>
          <span class="block text-[11px] text-muted uppercase tracking-wider mb-0.5">Pets</span>
          <span class="block text-base font-medium text-body-text">{unit.pets}</span>
        </div>
      </div>
    </div>

  </div>
</section>
