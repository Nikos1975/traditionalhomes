---
import { Image } from 'astro:assets';
import type { ListingItem } from '../utils/filters';
import inventory from '../inventory/inventory.json';
import type { InventoryUnit } from '../types';

interface Props {
  group: ListingItem;
  priority?: boolean;
}

const { group, priority = false } = Astro.props;

// 1. DYNAMIC IMAGE LOADING
const allImages = import.meta.glob('/src/assets/images/**/*.{webp,jpg,jpeg,png}', { eager: true });

const getHeroAsset = (slug: string | undefined) => {
  if (!slug) return null;
  const folder = `/src/assets/images/houses/${slug}/`;
  const imgs = Object.keys(allImages).filter(k => k.includes(folder));
  return (allImages[imgs.find(k => k.toLowerCase().includes('hero')) || imgs[0]] as any)?.default ?? null;
};

const firstMemberSlug  = group.members?.[0];
const secondMemberSlug = group.members?.[1];
const imgA = getHeroAsset(firstMemberSlug);
const imgB = getHeroAsset(secondMemberSlug);

// 2. DATA MAPPING
const units = inventory as InventoryUnit[];
const memberNames = group.members?.map(m => units.find(u => u.slug === m)?.name ?? m).join(' & ');
const nameA = units.find(u => u.slug === firstMemberSlug)?.name ?? firstMemberSlug ?? '';
const nameB = units.find(u => u.slug === secondMemberSlug)?.name ?? secondMemberSlug ?? '';
const detailPathA = firstMemberSlug ? `/en/houses/${firstMemberSlug}/` : '#';
const detailPathB = secondMemberSlug ? `/en/houses/${secondMemberSlug}/` : '#';
---

<article
  class="group bg-white rounded-[2rem] overflow-hidden border border-stone-100 shadow-premium hover:shadow-premium-hover hover:-translate-y-1 transition-all duration-500 flex flex-col"
  data-id={group.id}
>
  {/* IMAGE SECTION — diagonal split */}
  <div class="block relative overflow-hidden bg-stone-900 aspect-[4/3]">

    {/* Left photo (member A) */}
    <div class="absolute inset-0" style="clip-path: polygon(0 0, 62% 0, 38% 100%, 0 100%);">
      {imgA ? (
        <Image
          src={imgA}
          alt={nameA}
          width={600}
          height={450}
          loading={priority ? 'eager' : 'lazy'}
          class="w-full h-full object-cover opacity-95 transition-transform duration-[10s] ease-out group-hover:scale-105"
        />
      ) : (
        <div class="w-full h-full bg-stone-800" />
      )}
    </div>

    {/* Right photo (member B) */}
    <div class="absolute inset-0" style="clip-path: polygon(62% 0, 100% 0, 100% 100%, 38% 100%);">
      {imgB ? (
        <Image
          src={imgB}
          alt={nameB}
          width={600}
          height={450}
          loading={priority ? 'eager' : 'lazy'}
          class="w-full h-full object-cover opacity-95 transition-transform duration-[10s] ease-out group-hover:scale-105"
        />
      ) : (
        <div class="w-full h-full bg-stone-700" />
      )}
    </div>

    {/* Diagonal divider line aligned to the same split seam */}
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: rgba(255,255,255,0.55); clip-path: polygon(61.5% 0, 62.5% 0, 38.5% 100%, 37.5% 100%);"
    ></div>

    {/* House name labels */}
    <span class="absolute bottom-3 left-3 px-2 py-1 bg-stone-900/65 text-white text-[9px] font-bold uppercase tracking-[0.15em] rounded-full backdrop-blur-sm shadow">
      {nameA}
    </span>
    <span class="absolute bottom-3 right-3 px-2 py-1 bg-stone-900/65 text-white text-[9px] font-bold uppercase tracking-[0.15em] rounded-full backdrop-blur-sm shadow">
      {nameB}
    </span>

    {/* PREMIUM ESTATE BADGE */}
    <span class="absolute top-4 right-4 px-3 py-1.5 bg-stone-900/80 text-white text-[9px] uppercase font-bold tracking-[0.2em] rounded-full shadow-md backdrop-blur-md">
      Private Estate
    </span>
  </div>

  <div class="flex flex-col flex-1 p-8">
    
    {/* HEADER */}
    <div class="mb-6">
      <p class="text-[9px] uppercase tracking-[0.3em] text-stone-400 mb-2 font-bold">Mavrikiano · Elounda</p>
      <h2 class="font-serif text-3xl text-body-text leading-tight block">
        {group.name}
      </h2>
    </div>

    {/* INCLUDED PROPERTIES HIGHLIGHT */}
    <div class="mb-6 p-4 bg-stone-50/70 border border-stone-100 rounded-2xl">
      <span class="flex items-start gap-3 text-sm text-stone-600 font-medium leading-relaxed">
        <svg class="mt-0.5 flex-shrink-0 text-primary/70" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span>Includes: {memberNames}</span>
      </span>
    </div>

    {/* SPECS GRID */}
    <div class="grid grid-cols-2 gap-y-4 mb-8">
      <span class="flex items-center gap-3 text-xs text-stone-500 font-light">
        <svg class="text-stone-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Up to {group.sleepsMax} Guests
      </span>
      <span class="flex items-center gap-3 text-xs text-stone-500 font-light">
        <svg class="text-stone-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></svg>
        {group.bedrooms} Bedrooms
      </span>
      
      {/* POOL STATUS INTEGRATED INTO GRID */}
      {group.poolAccess && group.poolAccess !== 'none' && (
        <span class="flex items-center gap-3 text-xs text-primary font-medium col-span-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 12h20M2 12c0-5.5 4.5-10 10-10s10 4.5 10 10M2 12c0 5.5 4.5 10 10 10s10-4.5 10-10"/></svg>
          {group.poolAccess === 'exclusive_shared' ? 'Exclusive Estate Pool Area' : 'Private Pools Included'}
        </span>
      )}
    </div>

    {/* BOOKING INSTRUCTIONS (Editorial Note Style) */}
    <div class="mb-8 p-4 bg-amber-50/50 border border-amber-100 rounded-2xl mt-auto">
      <p class="text-[11px] text-amber-900/80 leading-relaxed italic">
        <strong>Editor's Note:</strong> Select both properties for the exact same dates on our booking engine to secure this group estate.
      </p>
    </div>

    {/* ACTIONS */}
    <div class="pt-6 border-t border-stone-100 grid grid-cols-1 sm:grid-cols-3 gap-3">
      <a href={detailPathA} class="btn-outline py-3 px-0 text-center rounded-xl bg-white shadow-sm hover:shadow-md transition-shadow">
        View {nameA}
      </a>
      <a href={detailPathB} class="btn-outline py-3 px-0 text-center rounded-xl bg-white shadow-sm hover:shadow-md transition-shadow">
        View {nameB}
      </a>
      <a 
        href="https://traditionalhomes.reserve-online.net/" 
        target="_blank" 
        rel="noopener" 
        class="btn-cta py-3 px-0 text-center rounded-xl shadow-md"
      >
        Check Dates
      </a>
    </div>
  </div>
</article>
