---
import type { InventoryUnit } from '../types';
import gallery from '../data/gallery.json';

interface Props {
  unit: InventoryUnit;
}

const { unit } = Astro.props;
const unitPagePath = unit.type === 'villa' ? `/en/villa/${unit.slug}/` : `/en/houses/${unit.slug}/`;
const galleryData = (gallery as Record<string, { src: string; alt: string; isFeatured: boolean; srcset?: string }[]>)[unit.slug] ?? [];
const featuredImg = galleryData.find((img) => img.isFeatured);
---

<article
  class="group bg-white rounded-xl overflow-hidden shadow-card hover:shadow-card-hover transition-shadow duration-300 flex flex-col"
  data-id={unit.slug}
>
  <a href={unitPagePath} class="block relative overflow-hidden bg-stone-200" style="aspect-ratio: 4/3;" tabindex="-1" aria-hidden="true">
    <img
      src={featuredImg?.src ?? '/images/placeholder.svg'}
      srcset={featuredImg?.srcset}
      sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
      alt={featuredImg?.alt ?? unit.name}
      width="600"
      height="450"
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      onerror="this.src='/images/placeholder.svg'"
    />
    {unit.pool !== 'none' && (
      <span class:list={['absolute top-3 left-3', unit.pool === 'shared' ? 'badge-shared-pool' : 'badge-pool']}>
        {unit.pool === 'private' ? (
          <>
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12h20M2 12c0-5.5 4.5-10 10-10s10 4.5 10 10M2 12c0 5.5 4.5 10 10 10s10-4.5 10-10"/></svg>
            Pool
          </>
        ) : (
          <>Shared Pool</>
        )}
      </span>
    )}
  </a>

  <div class="flex flex-col flex-1 p-5">
    <div class="flex items-start justify-between gap-2 mb-2">
      <div>
        <a href={unitPagePath} class="font-serif text-xl text-body-text hover:text-stone-600 transition-colors duration-150 leading-tight block">
          {unit.name}
        </a>
        <p class="text-xs text-muted mt-0.5">{unit.location}, {unit.area}</p>
      </div>
      {unit.type === 'villa' && (
        <span class="badge bg-footer-bg text-white mt-0.5 flex-shrink-0">Villa</span>
      )}
    </div>

    <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-stone-600 mb-3 mt-1">
      <span class="flex items-center gap-1">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Sleeps {unit.sleeps_max}
      </span>
      <span class="flex items-center gap-1">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></svg>
        {unit.bedrooms} {unit.bedrooms === 1 ? 'bedroom' : 'bedrooms'}
      </span>
      <span class="flex items-center gap-1">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="2" ry="2"/><path d="M12 2v20"/><path d="M2 12h20"/></svg>
        {unit.internal_stairs ? 'Internal stairs' : 'No internal stairs'}
      </span>
      {(unit.view.toLowerCase().includes('sea') || unit.view.toLowerCase().includes('bay')) && (
        <span class="flex items-center gap-1 text-sky-700 font-medium">
          Sea view
        </span>
      )}
    </div>

    {unit.internal_stairs && (
      <div class="mb-3">
        <span class="badge-stairs">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          Internal stairs
        </span>
      </div>
    )}

    {unit.access_detail && (
      <p class="text-xs text-amber-800 bg-amber-50 border border-amber-200 rounded px-2.5 py-1.5 mb-4 leading-snug">
        {unit.access_detail}
      </p>
    )}

    <div class="mt-auto pt-3 border-t border-stone-100 flex gap-2">
      <a href={unitPagePath} class="btn-outline flex-1 text-xs py-2.5 text-center">
        View details
      </a>
      <a
        href={unit.availability_url}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-cta flex-1 text-xs py-2.5"
      >
        Check availability
      </a>
    </div>
  </div>
</article>
