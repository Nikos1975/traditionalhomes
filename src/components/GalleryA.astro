---
import { Image } from 'astro:assets';
import type { GalleryImage } from '../types'; 

interface Props {
  images: any[]; 
  unitName: string;
}

const { images, unitName } = Astro.props;

// 1. Separate featured and thumbnails
const featured = images.find((img) => img.src.toLowerCase().includes('hero') || img.src.toLowerCase().includes('featured')) ?? images[0];
const thumbs = images.filter((img) => img !== featured);

// 2. Unfragmented Array: Combine them so the lightbox can swipe through EVERY photo
const allGalleryImages = featured ? [featured, ...thumbs] : thumbs;

// Prepare the JSON for the client-side script
const galleryData = allGalleryImages.map((img, i) => ({
  src: img.src,
  alt: i === 0 ? `Main view of ${unitName}` : `${unitName} - Photo ${i}`
}));
---

<section class="mb-16" aria-label={`Photos of ${unitName}`}>
  
  {/* FEATURED IMAGE CONTAINER */}
  <button 
    class="group block relative w-full overflow-hidden rounded-[2rem] bg-stone-900 shadow-premium cursor-pointer outline-none focus-visible:ring-4 focus-visible:ring-stone-400 transition-shadow"
    style="aspect-ratio: 16/9; max-height: 70vh;"
    data-lightbox-trigger
    data-index="0"
    aria-label={`Open main photo of ${unitName} in fullscreen`}
  >
    {featured ? (
      <Image
        src={featured}
        alt={`Main view of ${unitName}`}
        width={1280}
        height={720}
        widths={[640, 1024, 1280, 1600]}
        sizes="(min-width: 1024px) 66vw, 100vw"
        class="w-full h-full object-cover opacity-95 transition-transform duration-[10s] ease-out group-hover:scale-105"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        data-main-hero
      />
    ) : (
      <div class="w-full h-full flex flex-col items-center justify-center bg-stone-100 text-stone-400">
        <p class="text-[10px] uppercase tracking-[0.2em] font-bold">Photo coming soon</p>
      </div>
    )}
    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-500"></div>
  </button>

  {/* THUMBNAILS GRID */}
  {thumbs.length > 0 && (
    <div class="mt-6 grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 gap-4" role="list" aria-label="Photo thumbnails">
      {thumbs.map((img, i) => (
        <button
          type="button"
          class="group relative overflow-hidden rounded-[1.25rem] bg-stone-900 aspect-square cursor-pointer border-[3px] border-transparent hover:border-stone-300 focus:border-stone-900 focus:outline-none transition-all duration-300 shadow-sm hover:shadow-md"
          aria-label={`View photo ${i + 1} of ${unitName}`}
          data-lightbox-trigger
          data-index={featured ? i + 1 : i} 
          role="listitem"
        >
          <Image
            src={img}
            alt={`${unitName} detail ${i + 1}`}
            width={200}
            height={200}
            class="w-full h-full object-cover opacity-90 transition-transform duration-[5s] ease-out group-hover:scale-110"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300"></div>
          <span class="sr-only">Open image {i + 1} in lightbox</span>
        </button>
      ))}
    </div>
  )}
</section>

{/* Hidden Data for the Script */}
<script type="application/json" id="gallery-data" set:html={JSON.stringify(galleryData)}></script>

{/* FULL-FEATURED EDITORIAL LIGHTBOX */}
<dialog
  id="gallery-lightbox"
  class="fixed inset-0 w-full h-full max-w-none max-h-none m-0 border-none p-0 bg-stone-950/95 backdrop:bg-stone-950/95 overflow-hidden text-white"
  aria-label="Photo viewer"
  aria-modal="true"
>
  <div class="relative w-full h-full flex flex-col items-center justify-center p-6">
    
    {/* Navigation UI */}
    <div class="absolute top-6 right-6 flex items-center gap-6 z-50">
      <span id="lightbox-counter" class="text-sm font-serif italic tracking-widest text-white/70"></span>
      <button id="lightbox-close" class="p-3 hover:bg-white/10 rounded-full transition-colors outline-none focus-visible:ring-2 focus-visible:ring-white/50" aria-label="Close viewer">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <button id="lightbox-prev" class="absolute left-6 top-1/2 -translate-y-1/2 z-50 p-4 hover:bg-white/10 rounded-full transition-all hidden md:flex outline-none focus-visible:ring-2 focus-visible:ring-white/50" aria-label="Previous">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>

    <button id="lightbox-next" class="absolute right-6 top-1/2 -translate-y-1/2 z-50 p-4 hover:bg-white/10 rounded-full transition-all hidden md:flex outline-none focus-visible:ring-2 focus-visible:ring-white/50" aria-label="Next">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    {/* Image Display */}
    <figure class="flex flex-col items-center gap-6 w-full max-w-7xl animate-in fade-in zoom-in duration-500">
      <div class="relative w-full flex justify-center">
        <img
          id="lightbox-img"
          src=""
          alt=""
          class="max-h-[80vh] max-w-full rounded-lg shadow-2xl object-contain select-none"
        />
      </div>
      <figcaption id="lightbox-caption" class="font-serif text-xl md:text-2xl font-light text-white/90 text-center max-w-2xl leading-relaxed tracking-wide"></figcaption>
    </figure>
  </div>
</dialog>

<script>
  const dataElement = document.getElementById('gallery-data');
  const galleryImages = JSON.parse(dataElement?.textContent || '[]');
  
  const lightbox = document.getElementById('gallery-lightbox') as HTMLDialogElement;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lightbox-caption');
  const lbCounter = document.getElementById('lightbox-counter');
  
  const triggers = document.querySelectorAll('[data-lightbox-trigger]');
  const closeBtn = document.getElementById('lightbox-close');
  const prevBtn = document.getElementById('lightbox-prev');
  const nextBtn = document.getElementById('lightbox-next');

  let currentIndex = 0;

  function updateLightbox(index: number) {
    if (!lbImg || !lbCaption || !lbCounter || galleryImages.length === 0) return;
    
    // Handle wrap-around
    currentIndex = (index + galleryImages.length) % galleryImages.length;
    const current = galleryImages[currentIndex];
    
    lbImg.src = current.src;
    lbImg.alt = current.alt;
    lbCaption.textContent = current.alt;
    lbCounter.textContent = `${currentIndex + 1} / ${galleryImages.length}`;
  }

  // Event Listeners (Updated to read data-index)
  triggers.forEach((trigger) => {
    trigger.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLElement;
      const index = parseInt(btn.getAttribute('data-index') || '0', 10);
      updateLightbox(index);
      lightbox?.showModal();
      document.body.style.overflow = 'hidden'; // Prevent background scrolling
    });
  });

  const close = () => { 
    lightbox?.close(); 
    document.body.style.overflow = ''; 
  };
  
  closeBtn?.addEventListener('click', close);
  prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); updateLightbox(currentIndex - 1); });
  nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); updateLightbox(currentIndex + 1); });

  // Backdrop close
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) close(); });

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (!lightbox?.open) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') updateLightbox(currentIndex - 1);
    if (e.key === 'ArrowRight') updateLightbox(currentIndex + 1);
  });

  // Advanced Touch Handling (Swipe support)
  let touchStartX = 0;
  let touchEndX = 0;

  lightbox?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].clientX;
  }, { passive: true });

  lightbox?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].clientX;
    const swipeDistance = touchEndX - touchStartX;
    if (Math.abs(swipeDistance) > 80) {
      swipeDistance > 0 ? updateLightbox(currentIndex - 1) : updateLightbox(currentIndex + 1);
    }
  }, { passive: true });
</script>
