---
interface Props {
  images: any[];
  unitName: string;
}

const { images, unitName } = Astro.props;

const featured =
  images.find((img) => img.isFeatured) ??
  images.find((img) => img.src.toLowerCase().includes('hero')) ??
  images[0];

const rest = images.filter((img) => img !== featured);
const allImages = featured ? [featured, ...rest] : rest;
const thumbs = rest.slice(0, 5);
const totalCount = allImages.length;

const galleryItems = allImages.map((img, i) => ({
  src: img.src,
  srcset: img.srcset ?? '',
  alt: img.alt ?? (i === 0 ? `Main view of ${unitName}` : `${unitName} — Photo ${i + 1}`),
}));
---

{/* ── DESKTOP GALLERY (md+) ────────────────────── */}
<section class="mb-12 hidden md:block" aria-label={`Photos of ${unitName}`}>

  {/* Hero */}
  <button
    class="group block relative w-full overflow-hidden rounded-2xl bg-stone-200 cursor-pointer"
    style="aspect-ratio: 16/9; max-height: 65vh;"
    data-lb-open="0"
    aria-label={`View photos of ${unitName}`}
  >
    {featured ? (
      <img
        src={featured.src}
        srcset={featured.srcset}
        sizes="(min-width:1024px) 66vw, 100vw"
        alt={`Main view of ${unitName}`}
        class="w-full h-full object-cover transition-transform duration-[10s] ease-out group-hover:scale-105"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-stone-100 text-stone-400 text-xs uppercase tracking-widest">
        Photo coming soon
      </div>
    )}
    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-500"></div>
  </button>

  {/* Thumbnail strip */}
  {allImages.length > 1 && (
    <div class="mt-3 flex items-stretch gap-2">
      {thumbs.map((img, i) => (
        <button
          type="button"
          class="group relative flex-1 overflow-hidden rounded-xl bg-stone-200 cursor-pointer border-2 border-transparent hover:border-stone-400 focus:border-stone-700 focus:outline-none transition-all duration-200"
          style="aspect-ratio: 4/3;"
          data-lb-open={i + 1}
          aria-label={`View photo ${i + 2} of ${unitName}`}
        >
          <img
            src={img.src}
            srcset={img.srcset}
            sizes="15vw"
            alt={`${unitName} — photo ${i + 2}`}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/15 transition-colors duration-300"></div>
        </button>
      ))}

      {totalCount > 1 && (
        <button
          type="button"
          class="flex-shrink-0 flex flex-col items-center justify-center gap-2 px-6 rounded-xl gallery-view-all-cta"
          data-lb-open="0"
          aria-label={`View all ${totalCount} photos`}
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
          </svg>
          <span class="text-[10px] font-bold uppercase tracking-widest whitespace-nowrap">All {totalCount}<br/>photos</span>
        </button>
      )}
    </div>
  )}
</section>

{/* ── MOBILE GALLERY (<md) ─────────────────────── */}
<section class="mb-8 md:hidden" aria-label={`Photos of ${unitName}`}>
  <div
    class="flex overflow-x-auto gap-3 pb-1 rounded-2xl"
    style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none;"
    id="mobile-track"
  >
    {allImages.slice(0, 10).map((img, i) => (
      <div
        class="shrink-0 w-full relative overflow-hidden rounded-2xl bg-stone-200 cursor-pointer"
        style="aspect-ratio: 4/3; scroll-snap-align: start;"
        data-lb-open={i}
        role="button"
        tabindex="0"
        aria-label={`View photo ${i + 1}`}
      >
        <img
          src={img.src}
          srcset={img.srcset}
          sizes="100vw"
          alt={img.alt}
          class="w-full h-full object-cover"
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
        />
      </div>
    ))}
  </div>

  {totalCount > 1 && (
    <button
      type="button"
      class="mt-3 w-full flex items-center justify-center gap-2 py-3 gallery-view-all-cta rounded-xl text-[11px] uppercase tracking-widest font-bold"
      data-lb-open="0"
      aria-label={`View all ${totalCount} photos`}
    >
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
        <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
      </svg>
      View all {totalCount} photos
    </button>
  )}
</section>

{/* ── LIGHTBOX ─────────────────────────────────── */}
<dialog
  id="gallery-lb"
  class="fixed inset-0 w-full h-full max-w-none max-h-none m-0 p-0 border-none bg-stone-950/98 text-white overflow-hidden"
  aria-modal="true"
  aria-label={`${unitName} photo viewer`}
>
  <div class="w-full h-full flex flex-col">

    {/* Top bar */}
    <div class="flex items-center justify-between px-5 py-3 shrink-0 border-b border-white/10">
      <span id="lb-counter" class="font-serif text-sm tracking-widest text-white/60 tabular-nums"></span>
      <button
        id="lb-close"
        class="w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 transition-colors"
        aria-label="Close photo viewer"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    {/* Image + arrows */}
    <div class="relative flex-1 flex items-center justify-center min-h-0 px-20">

      {/* PREV — white pill, always visible */}
      <button
        id="lb-prev"
        class="absolute left-4 z-20 w-12 h-12 flex items-center justify-center rounded-full bg-white text-stone-900 shadow-2xl hover:scale-105 active:scale-95 transition-transform"
        aria-label="Previous photo"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>

      <img
        id="lb-img"
        src=""
        alt=""
        class="max-h-full max-w-full object-contain select-none rounded-md shadow-2xl"
      />

      {/* NEXT — white pill, always visible */}
      <button
        id="lb-next"
        class="absolute right-4 z-20 w-12 h-12 flex items-center justify-center rounded-full bg-white text-stone-900 shadow-2xl hover:scale-105 active:scale-95 transition-transform"
        aria-label="Next photo"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
    </div>

    {/* Caption */}
    <p id="lb-caption" class="text-center text-sm text-white/40 py-3 px-8 shrink-0 font-serif italic truncate"></p>
  </div>
</dialog>

<script is:inline define:vars={{ galleryItems }}>
  var lb = document.getElementById('gallery-lb');
  var lbImg = document.getElementById('lb-img');
  var lbCaption = document.getElementById('lb-caption');
  var lbCounter = document.getElementById('lb-counter');
  var idx = 0;

  function show(newIdx) {
    if (!lb || !lbImg || galleryItems.length === 0) return;
    idx = (newIdx + galleryItems.length) % galleryItems.length;
    var item = galleryItems[idx];
    lbImg.src = item.src;
    lbImg.srcset = item.srcset || '';
    lbImg.alt = item.alt;
    if (lbCaption) lbCaption.textContent = item.alt;
    if (lbCounter) lbCounter.textContent = (idx + 1) + ' / ' + galleryItems.length;
  }

  function openLb(startIdx) {
    show(startIdx);
    lb.showModal();
    document.body.style.overflow = 'hidden';
  }

  function closeLb() {
    lb.close();
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-lb-open]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      openLb(parseInt(btn.getAttribute('data-lb-open') || '0', 10));
    });
    btn.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') openLb(parseInt(btn.getAttribute('data-lb-open') || '0', 10));
    });
  });

  document.getElementById('lb-close').addEventListener('click', closeLb);
  document.getElementById('lb-prev').addEventListener('click', function(e) { e.stopPropagation(); show(idx - 1); });
  document.getElementById('lb-next').addEventListener('click', function(e) { e.stopPropagation(); show(idx + 1); });

  lb.addEventListener('click', function(e) { if (e.target === lb) closeLb(); });

  document.addEventListener('keydown', function(e) {
    if (!lb.open) return;
    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft') show(idx - 1);
    if (e.key === 'ArrowRight') show(idx + 1);
  });

  var touchX = 0;
  lb.addEventListener('touchstart', function(e) { touchX = e.changedTouches[0].clientX; }, { passive: true });
  lb.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].clientX - touchX;
    if (Math.abs(dx) > 60) { dx > 0 ? show(idx - 1) : show(idx + 1); }
  }, { passive: true });
</script>
